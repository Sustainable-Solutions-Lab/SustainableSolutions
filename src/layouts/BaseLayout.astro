---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CoordReadout from '../components/CoordReadout.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  showCoordReadout?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description = 'Sustainable Solutions Lab — Stanford Doerr School of Sustainability. Underexamined questions. Lasting answers.',
  showCoordReadout = false,
  hideFooter = false,
} = Astro.props;

const fullTitle = title === 'Sustainable Solutions Lab'
  ? title
  : `${title} · Sustainable Solutions Lab`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F8F8E8" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body class="bg-paper text-ink font-sans antialiased">
    <Nav />
    <main id="main">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    {showCoordReadout && <CoordReadout />}

    {/* Vercel Web Analytics + Speed Insights — privacy-friendly, no cookies,
        no PII. Only emits events on production deployments. */}
    <Analytics />
    <SpeedInsights />

    <script is:inline>
      // Theme bootstrap — runs before paint to avoid flash.
      (function () {
        const stored = localStorage.getItem('ssl-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored ?? (prefersDark ? 'dark' : 'light');
        if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
    <script is:inline>
      // External links (marked with data-external) open in a new tab with
      // safe rel attributes. Single place to enforce the convention so every
      // page picks it up automatically — author code only needs the data-
      // attribute.
      (function () {
        function tagExternals() {
          for (const a of document.querySelectorAll('a[data-external]')) {
            if (!a.target) a.target = '_blank';
            if (!a.rel)    a.rel    = 'noopener noreferrer';
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', tagExternals);
        } else {
          tagExternals();
        }
      })();
    </script>
  </body>
</html>
