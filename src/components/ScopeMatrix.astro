---
// Lab-scope heatmap — vertical layout, sits beside the hero lede.
//
// Columns = systems     (Energy · Food · Water · Materials · Climate · Health)
// Rows    = response type, two sections separated by a section header:
//             MITIGATION:  General · Trade · Carbon mgmt
//             IMPACTS &
//             ADAPTATION:  General · Air · Heat · Drought · Fire · Flood
//
// Each COLUMN uses its system's Spectral hue. Cell saturation scales
// against the maximum count anywhere in that column — so each system's
// densest cell hits full saturation, regardless of how busy other
// systems are.

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

// Darker, more-saturated hues for Energy and Food than the raw Spectral
// palette — Spectral-3 (#F46D43) and Spectral-9 (#66C2A5) lose too much
// punch when mixed with cream paper. The other four use the palette
// directly because their natural luminance already contrasts well.
const SYSTEMS = [
  { key: 'energy',    label: 'Energy',    color: '#C2440E'            }, // burnt orange
  { key: 'food',      label: 'Food',      color: '#1F7A4D'            }, // forest green
  { key: 'water',     label: 'Water',     color: 'var(--spectral-10)' }, // blue
  { key: 'materials', label: 'Materials', color: 'var(--spectral-11)' }, // purple
  { key: 'climate',   label: 'Climate',   color: 'var(--spectral-1)'  }, // wine
  { key: 'health',    label: 'Health',    color: 'var(--spectral-2)'  }, // red
] as const;

const MIT_ROWS = [
  { key: 'general',           label: 'General',     match: 'mitigation' },
  { key: 'trade',             label: 'Trade',       match: 'mitigation:trade' },
  { key: 'carbon-management', label: 'Carbon mgmt', match: 'mitigation:carbon-management' },
] as const;

const IMP_ROWS = [
  { key: 'general',       label: 'General',       match: 'impacts' },
  { key: 'air-pollution', label: 'Air pollution', match: 'impacts:air-pollution' },
  { key: 'heat',          label: 'Heat',          match: 'impacts:heat' },
  { key: 'drought',       label: 'Drought',       match: 'impacts:drought' },
  { key: 'fire',          label: 'Fire',          match: 'impacts:fire' },
  { key: 'flooding',      label: 'Flooding',      match: 'impacts:flooding' },
] as const;

const pubs = publications as Publication[];

function axisMatches(values: string[], target: string): boolean {
  for (const v of values) {
    if (v === target) return true;
    if (v.startsWith(target + ':')) return true;
  }
  return false;
}

const cellCount: Record<string, number> = {};
const colMax: Record<string, number> = {};
for (const sys of SYSTEMS) {
  let m = 0;
  for (const row of [...MIT_ROWS, ...IMP_ROWS]) {
    let n = 0;
    for (const p of pubs) {
      const s = (p.system ?? []) as string[];
      const r = (p.response ?? []) as string[];
      if (axisMatches(s, sys.key) && axisMatches(r, row.match)) n++;
    }
    cellCount[`${sys.key}|${row.key}`] = n;
    if (n > m) m = n;
  }
  colMax[sys.key] = m;
}

function cellBg(systemKey: string, base: string, count: number): string {
  const max = colMax[systemKey] || 1;
  if (!count) return 'var(--paper-2)';
  // Higher floor (0.32) so even single-paper cells read clearly; max → 1.0
  // so the densest cell of each column is fully saturated.
  const opacity = 0.32 + (count / max) * 0.68;
  return `color-mix(in oklab, ${base} ${(opacity * 100).toFixed(0)}%, var(--paper))`;
}
---

<figure class="scope-figure">
  <p class="scope-eyebrow">
    <span class="cardinal-dot"></span>FIGURE · LAB SCOPE
  </p>
  <h3 class="scope-headline">Where the lab works</h3>
  <p class="scope-subtitle">
    <em>Publications by system × response</em>
  </p>

  <div class="scope-grid">
    {/* Column headers — system labels in their own hue */}
    <div></div>
    {SYSTEMS.map((s) => (
      <div class="col-label" style={`color: ${s.color};`}>{s.label}</div>
    ))}

    {/* Mitigation section header */}
    <div class="section-label section-mit">Mitigation</div>

    {MIT_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(s.key, s.color, count)};`}
              title={`${s.label} × Mitigation: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </>
    ))}

    {/* Impacts section header */}
    <div class="section-label section-imp">Impacts &amp; Adaptation</div>

    {IMP_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(s.key, s.color, count)};`}
              title={`${s.label} × Impacts: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </>
    ))}
  </div>

  <figcaption class="scope-caption">
    <em>Each column is a system the lab studies. Hue identifies the
    system; saturation scales with the number of papers tagged in
    that cell. Hover for counts.</em>
  </figcaption>
</figure>

<style>
  .scope-figure {
    margin: 0;
    width: 100%;
  }
  .scope-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cardinal);
    margin: 0 0 6px;
  }
  .scope-headline {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .scope-subtitle {
    font-family: var(--font-serif);
    font-size: 13px;
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 12px;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: minmax(80px, max-content) repeat(6, 1fr);
    gap: 2px;
    align-items: stretch;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
    padding: 0 2px 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    align-self: end;
  }

  .section-label {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 4px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--rule);
  }
  .section-mit { color: var(--spectral-10); }
  .section-imp { color: var(--spectral-2); }

  .row-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    text-align: right;
    padding-right: 6px;
    align-self: center;
  }

  .cell {
    background: var(--paper-2);
    border-radius: 2px;
    height: 18px;
    transition: outline 0.12s ease;
  }
  .cell:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }

  .scope-caption {
    margin: 12px 0 0;
    font-family: var(--font-serif);
    font-size: 12px;
    line-height: 1.45;
    color: var(--ink-3);
    max-width: 32ch;
  }
</style>
