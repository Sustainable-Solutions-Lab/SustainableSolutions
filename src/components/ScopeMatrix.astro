---
// Compact lab-scope heatmap.
//
// Two stacked 4×4 grids representing the lab's scope:
//   • Top section — Mitigation (blue end of Spectral)
//        rows: General · Trade · Corporate · Carbon mgmt
//   • Bottom section — Impacts & Adaptation (red end of Spectral)
//        rows: General · Air pollution · Heat · Flooding
//   columns (both sections): Energy · Food · Water · Materials
//
// Cell color = section base color (Spectral-10 for mitigation,
// Spectral-2 for impacts) at opacity scaled by paper count within
// the section. Empty cells stay paper-colored. Hover surfaces the
// full label.
//
// Multi-tagged papers contribute to every matching cell — the
// visual shows breadth, not a partition.

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const COLUMNS = [
  { key: 'energy',    label: 'Energy',    tags: ['energy', 'electricity'] },
  { key: 'food',      label: 'Food',      tags: ['food', 'land'] },
  { key: 'water',     label: 'Water',     tags: ['water'] },
  { key: 'materials', label: 'Materials', tags: ['materials'] },
] as const;

const SECTIONS = [
  {
    key: 'mitigation',
    label: 'Mitigation',
    base: 'var(--spectral-10)',  // blue end
    rows: [
      { key: 'general',     label: 'General',      tags: ['emissions'] },
      { key: 'trade',       label: 'Trade',        tags: ['trade'] },
      { key: 'corporate',   label: 'Corporate',    tags: ['corporate'] },
      { key: 'carbon-mgmt', label: 'Carbon mgmt',  tags: ['carbon management'] },
    ],
  },
  {
    key: 'impacts',
    label: 'Impacts & Adaptation',
    base: 'var(--spectral-2)',  // red end
    rows: [
      { key: 'general',       label: 'General',       tags: ['impacts', 'fire'] },
      { key: 'air-pollution', label: 'Air pollution', tags: ['air pollution'] },
      { key: 'heat',          label: 'Heat',          tags: ['heat'] },
      { key: 'flooding',      label: 'Flooding',      tags: ['flooding'] },
    ],
  },
] as const;

const pubs = publications as Publication[];

function intersects(a: readonly string[], b: readonly string[]) {
  for (const x of a) if (b.includes(x)) return true;
  return false;
}

// Pre-compute counts per cell, plus the per-section max for opacity scaling.
const cellCount: Record<string, number> = {};
const sectionMax: Record<string, number> = {};
for (const sec of SECTIONS) {
  let secMax = 0;
  for (const col of COLUMNS) {
    for (const row of sec.rows) {
      let n = 0;
      for (const p of pubs) {
        const themes = (p.themes ?? []) as string[];
        if (intersects(col.tags, themes) && intersects(row.tags, themes)) n++;
      }
      cellCount[`${sec.key}|${row.key}|${col.key}`] = n;
      if (n > secMax) secMax = n;
    }
  }
  sectionMax[sec.key] = secMax;
}

function cellBg(secKey: string, base: string, count: number): string {
  const max = sectionMax[secKey] || 1;
  if (!count) return 'var(--paper)';
  // 0.15 floor so even count=1 cells are faintly visible.
  const opacity = 0.15 + (count / max) * 0.78;
  return `color-mix(in oklab, ${base} ${(opacity * 100).toFixed(0)}%, var(--paper))`;
}
---

<div class="scope-matrix-mini" aria-label="Scope of lab publications">
  {SECTIONS.map((sec) => (
    <div class="scope-section" data-section={sec.key}>
      {sec.rows.flatMap((row) =>
        COLUMNS.map((col) => {
          const count = cellCount[`${sec.key}|${row.key}|${col.key}`] ?? 0;
          return (
            <div
              class="scope-cell-mini"
              style={`background-color: ${cellBg(sec.key, sec.base, count)};`}
              title={`${col.label} × ${sec.label}: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        }),
      )}
    </div>
  ))}
</div>

<style>
  .scope-matrix-mini {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 124px;
    flex: none;
  }
  .scope-section {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    aspect-ratio: 1 / 1;
    gap: 2px;
    padding: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
  }
  .scope-cell-mini {
    background: var(--paper);
    transition: outline 0.12s ease;
  }
  .scope-cell-mini:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }
</style>
