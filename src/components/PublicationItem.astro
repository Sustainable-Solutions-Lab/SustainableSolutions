---
import type { Publication, Person } from '../lib/types';
import people from '../data/people.json';
import scholarDetails from '../../templates/scholar-details.json';
import { splitAndLinkAuthors, toNaturalOrder } from '../lib/author-links';
import { themeColor, themeLabel } from '../lib/themes';
import { roleColor } from '../lib/roles';
import CitationChart from './CitationChart.astro';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  pub: Publication;
}

const { pub } = Astro.props;

// Build a {DOI → citations[]} lookup once at module load time. Survives
// the build because scholar-details.json is statically imported.
const citationsByDoi = new Map<string, Array<{ year: number; count: number }>>();
const totalsByDoi = new Map<string, number>();
for (const detail of Object.values(scholarDetails as Record<string, any>)) {
  if (detail?.doi && Array.isArray(detail.citations) && detail.citations.length > 0) {
    citationsByDoi.set(detail.doi, detail.citations);
    if (typeof detail.total_citations === 'number') {
      totalsByDoi.set(detail.doi, detail.total_citations);
    }
  }
}

const citationsForPub = pub.doi ? citationsByDoi.get(pub.doi) ?? null : null;
const totalCitationsForPub = pub.doi ? totalsByDoi.get(pub.doi) ?? null : null;

// Gate the impact row (citation chart + Altmetric/Dimensions badges) on a
// minimum citation count. Newer/uncited papers don't get a near-empty chart
// and an empty pair of badges screaming for attention.
const IMPACT_THRESHOLD = 100;
const showImpact = (totalCitationsForPub ?? 0) >= IMPACT_THRESHOLD;

// Sort scores. Used by the publications page's Sort dropdown via data-* attrs.
const currentYear = new Date().getFullYear();
const totalCitationsScore = totalCitationsForPub ?? 0;
const yearsSincePub = Math.max(currentYear - pub.year + 1, 1);
const citationsPerYearScore =
  totalCitationsForPub != null ? totalCitationsForPub / yearsSincePub : 0;
const recent3yrScore = citationsForPub
  ? citationsForPub
      .filter((c) => c.year >= currentYear - 2)
      .reduce((sum, c) => sum + (c.count || 0), 0)
  : 0;

const doiUrl = pub.url ?? (pub.doi ? `https://doi.org/${pub.doi}` : null);

// Auto-detect lab members in the authors string (matches by last name +
// initials prefix, so "Davis, S." or "Davis, S.J." both link to Steve).
const peopleArr = people as Person[];
const peopleBySlug = new Map(peopleArr.map((p) => [p.slug, p]));
const authorSegments = splitAndLinkAuthors(pub.authors ?? '', peopleArr).map((seg) => {
  const person = seg.slug ? peopleBySlug.get(seg.slug) ?? null : null;
  return {
    ...seg,
    color: person ? roleColor(person.role) : null,
  };
});
const detectedLabSlugs = Array.from(
  new Set(authorSegments.filter((s) => s.slug).map((s) => s.slug as string)),
);

// Search blob — concatenated lowercase string the client-side filter greps.
const searchBlob = [pub.authors, pub.title, pub.journal, String(pub.year)]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();

// Citation tail: "9(3), 201–210"
const citationParts: string[] = [];
if (pub.volume_issue) citationParts.push(pub.volume_issue);
if (pub.pages) citationParts.push(pub.pages.replace(/-/g, '–'));
const citationTail = citationParts.join(', ');

// Featured cards get a hero block. If image_filename is set, look for the
// file in /public/publications/ first, then /public/images/ as a fallback,
// so the generic shared-images folder also works for pub heroes. Falls back
// to the typographic placeholder if the file isn't found in either spot.
const isFeatured = !!pub.featured;
function resolveHeroUrl(filename: string | null | undefined): string | null {
  if (!filename) return null;
  for (const folder of ['publications', 'images']) {
    if (existsSync(resolve('public', folder, filename))) return `/${folder}/${filename}`;
  }
  return null;
}
const heroImageUrl = resolveHeroUrl(pub.image_filename);

const spectralColors = [
  'var(--spectral-2)',
  'var(--spectral-3)',
  'var(--spectral-4)',
  'var(--spectral-9)',
  'var(--spectral-10)',
  'var(--spectral-11)',
];
const heroHash = [...(pub.doi || pub.title || '')].reduce(
  (a, c) => a + c.charCodeAt(0),
  0,
);
const heroAccent = spectralColors[heroHash % spectralColors.length];

// Theme color stripe — primary theme drives the left-edge color on
// non-featured cards. Falls back to neutral gray if no themes tagged.
const pubThemes = pub.themes ?? [];
const primaryThemeColor = pubThemes.length > 0 ? themeColor(pubThemes[0]) : 'var(--ink-4)';
---

<li
  class:list={['relative', isFeatured ? 'py-6' : 'py-6 border-b border-rule']}
  data-pub
  data-year={pub.year}
  data-month={pub.month ?? 0}
  data-themes={(pub.themes ?? []).join(',')}
  data-lab-authors={detectedLabSlugs.join(',')}
  data-featured={String(pub.featured)}
  data-total-citations={totalCitationsScore}
  data-citations-per-year={citationsPerYearScore.toFixed(3)}
  data-recent-citations={recent3yrScore}
  data-search={searchBlob}
>
  {isFeatured ? (
    <article
      class="grid md:grid-cols-[1fr_280px] gap-6 p-6 border border-rule bg-paper"
      style="border-radius: var(--radius-md);"
    >
      <div class="min-w-0">
        <p class="eyebrow m-0 mb-2">
          <span class="cardinal">FEATURED</span>
          <span class="dot">·</span>
          <em class="not-italic">{pub.journal}</em>
          <span class="dot">·</span>
          {pub.year}
        </p>

        <h3 class="m-0">
          {doiUrl ? (
            <a href={doiUrl} class="border-b-0 hover:underline" data-external>
              {pub.title}
            </a>
          ) : (
            pub.title
          )}
        </h3>

        <p class="text-ink-2 mt-2 text-sm m-0">
          {authorSegments.map((seg, i) => (
            <>
              {i > 0 && ', '}
              {seg.slug ? (
                <a href={`/people/${seg.slug}`} class="font-semibold bare" style={`white-space: nowrap; color: ${seg.color ?? 'var(--ink)'};`}>{toNaturalOrder(seg.text)}</a>
              ) : (
                <span style="white-space: nowrap;">{toNaturalOrder(seg.text)}</span>
              )}
            </>
          ))}
        </p>

        {pub.summary && (
          <p class="mt-3 font-serif text-ink m-0" style="font-size: 17px; line-height: 1.4;">
            {pub.summary}
          </p>
        )}

        {/* Single horizontal row: chart · badges · action links (matches
            the non-featured card; cleaner than three stacked rows). */}
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-4">
          {showImpact && citationsForPub && (
            <div class="shrink-0">
              <CitationChart citations={citationsForPub} total={totalCitationsForPub} />
            </div>
          )}
          {showImpact && pub.doi && (
            <div class="flex items-start gap-2 shrink-0">
              {/* Altmetric ~64px native → zoom 25/64 = 0.391 (renders ~25px). */}
              <div style="zoom: 0.390625;">
                <div
                  class="altmetric-embed"
                  data-badge-popover="right"
                  data-badge-type="medium-donut"
                  data-doi={pub.doi}
                ></div>
              </div>
              {/* Dimensions ~32px native → zoom 23/32 = 0.719 (renders ~23px,
                  2px smaller than Altmetric). */}
              <div style="zoom: 0.71875;">
                <div
                  class="__dimensions_badge_embed__"
                  data-doi={pub.doi}
                  data-style="small_circle"
                ></div>
              </div>
            </div>
          )}
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-mono uppercase tracking-wider ml-auto">
            {pub.pdf_url && (<a href={pub.pdf_url} class="text-ink-2 hover:text-ink border-b-0" data-external>PDF</a>)}
            {pub.code_url && (<a href={pub.code_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Code</a>)}
            {pub.brief_url && (<a href={pub.brief_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Brief</a>)}
            {pub.ppt_url && (<a href={pub.ppt_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Slides</a>)}
            {pub.press_url && (<a href={pub.press_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Press</a>)}
          </div>
        </div>
      </div>

      {heroImageUrl ? (
        <img
          src={heroImageUrl}
          alt={pub.title}
          loading="lazy"
          class="w-full object-cover border border-rule"
          style="aspect-ratio: 16/10; border-radius: var(--radius-md);"
        />
      ) : (
        <div
          aria-hidden="true"
          class="relative flex flex-col justify-end p-4 overflow-hidden"
          style={`
            aspect-ratio: 16/10;
            background: var(--paper-2);
            border: 1px solid var(--rule);
            border-left: 4px solid ${heroAccent};
            border-radius: var(--radius-md);
          `}
        >
          <p class="font-serif leading-tight m-0" style="font-size: 19px;">{pub.journal}</p>
          <p class="font-mono text-xs text-ink-3 mt-1 m-0">{pub.year}</p>
        </div>
      )}
    </article>
  ) : (
    <div
      class="pl-4"
      style={`border-left: 4px solid ${primaryThemeColor};`}
    >
      <p class="eyebrow m-0 mb-1" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <em class="not-italic">{pub.journal}</em>
        <span class="dot">·</span>
        {pub.year}
        {pubThemes.map((t) => (
          <>
            <span class="dot">·</span>
            <span style={`color: ${themeColor(t)};`}>{themeLabel(t).toUpperCase()}</span>
          </>
        ))}
      </p>

      <h3 class="m-0">
        {doiUrl ? (
          <a href={doiUrl} class="border-b-0 hover:underline" data-external>
            {pub.title}
          </a>
        ) : (
          pub.title
        )}
      </h3>

      <p class="text-ink-2 mt-2 text-sm m-0">
        {authorSegments.map((seg, i) => (
          <>
            {i > 0 && ', '}
            {seg.slug ? (
              <a href={`/people/${seg.slug}`} class="font-semibold bare" style={`white-space: nowrap; color: ${seg.color ?? 'var(--ink)'};`}>{toNaturalOrder(seg.text)}</a>
            ) : (
              <span style="white-space: nowrap;">{toNaturalOrder(seg.text)}</span>
            )}
          </>
        ))}
      </p>

      {/* Single horizontal row: chart · badges · action links. Wraps on narrow screens. */}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-3">
        {showImpact && citationsForPub && (
          <div class="shrink-0">
            <CitationChart citations={citationsForPub} total={totalCitationsForPub} />
          </div>
        )}
        {showImpact && pub.doi && (
          <div class="flex items-start gap-2 shrink-0">
            <div style="zoom: 0.390625;">
              <div
                class="altmetric-embed"
                data-badge-popover="right"
                data-badge-type="medium-donut"
                data-doi={pub.doi}
              ></div>
            </div>
            <div style="zoom: 0.71875;">
              <div
                class="__dimensions_badge_embed__"
                data-doi={pub.doi}
                data-style="small_circle"
              ></div>
            </div>
          </div>
        )}
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-mono uppercase tracking-wider ml-auto">
          {pub.pdf_url && (<a href={pub.pdf_url} class="text-ink-2 hover:text-ink border-b-0" data-external>PDF</a>)}
          {pub.code_url && (<a href={pub.code_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Code</a>)}
          {pub.brief_url && (<a href={pub.brief_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Brief</a>)}
          {pub.ppt_url && (<a href={pub.ppt_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Slides</a>)}
          {pub.press_url && (<a href={pub.press_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Press</a>)}
        </div>
      </div>
    </div>
  )}
</li>
