---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

const sorted = (tools as Tool[])
  .slice()
  .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

const pubsByDoi = new Map<string, Publication>();
for (const p of publications as Publication[]) {
  if (p.doi) pubsByDoi.set(p.doi.toLowerCase(), p);
}

function resolveImage(filename: string | null): string | null {
  if (!filename) return null;
  for (const folder of ['tools', 'images']) {
    if (existsSync(resolve('public', folder, filename))) return `/${folder}/${filename}`;
  }
  return null;
}

const cards = sorted.map((t) => {
  const companion = t.doi ? pubsByDoi.get(t.doi.trim().toLowerCase()) ?? null : null;
  return {
    ...t,
    imgUrl: resolveImage(t.image_filename),
    href: t.link ?? '#',
    isExternal: typeof t.link === 'string' && /^https?:\/\//.test(t.link),
    companion,
  };
});

// Cornerstone initiative card — special-treatment spotlight rendered
// above the sheet-driven tools. Logo file falls back gracefully: drop
// a SVG/PNG at /public/tools/cornerstone.svg or .png to replace the
// serif text overlay.
function resolveCornerstoneLogo(): string | null {
  for (const ext of ['svg', 'png', 'webp', 'jpg']) {
    const fname = `cornerstone.${ext}`;
    for (const folder of ['tools', 'images']) {
      if (existsSync(resolve('public', folder, fname))) return `/${folder}/${fname}`;
    }
  }
  return null;
}
const cornerstoneLogo = resolveCornerstoneLogo();
---

<BaseLayout title="Tools">
  <section class="container-content pt-8 pb-8">
    <p class="eyebrow mb-4">TOOLS</p>
    <h1>Things we ship</h1>
    <p class="lede max-w-prose mt-4">
      Interactive maps, datasets, and code releases that accompany our research.
    </p>
  </section>

  <section class="container-content pb-24">
    <ul class="list-none p-0 m-0 grid md:grid-cols-2 gap-6">
      {/*
        Cornerstone initiative — full-width card, spectral-gradient hero
        with logo overlay (or serif title fallback). Three external links
        in the footer go to website / Zenodo community / GitHub org.
      */}
      <li class="m-0 p-0 md:col-span-2">
        <article
          class="block bg-paper border border-rule overflow-hidden"
          style="border-radius: var(--radius-md);"
        >
          <div
            class="relative flex items-center justify-center"
            style="
              aspect-ratio: 16 / 5;
              background: linear-gradient(
                90deg,
                var(--spectral-1)  0%,
                var(--spectral-3)  18%,
                var(--spectral-5)  36%,
                var(--spectral-7)  54%,
                var(--spectral-9)  72%,
                var(--spectral-10) 88%,
                var(--spectral-11) 100%
              );
            "
          >
            {/* Soft paper overlay so the logo / title reads cleanly on the gradient. */}
            <div
              aria-hidden="true"
              class="absolute inset-0"
              style="background: color-mix(in oklab, var(--paper) 30%, transparent);"
            ></div>
            {cornerstoneLogo ? (
              <img
                src={cornerstoneLogo}
                alt="Cornerstone"
                class="relative block max-h-20 md:max-h-24 max-w-[60%]"
              />
            ) : (
              <p
                class="relative font-serif m-0"
                style="font-size: clamp(36px, 6vw, 64px); color: var(--ink); letter-spacing: -0.02em;"
              >
                Cornerstone
              </p>
            )}
          </div>
          <div class="p-6">
            <p class="eyebrow m-0 mb-2">INITIATIVE</p>
            <h3 class="m-0">Cornerstone</h3>
            <p class="text-ink-2 text-sm mt-2 m-0" style="line-height: 1.5;">
              An open-data initiative the lab participates in. Description goes
              here — replace this paragraph with one that captures Cornerstone's
              mission and the lab's role.
            </p>
            <div class="flex flex-wrap gap-x-5 gap-y-1 mt-4 font-mono text-xs uppercase tracking-wider">
              <a
                href="https://cornerstonedata.org/"
                class="text-ink-2 hover:text-ink border-b-0"
                target="_blank"
                rel="noopener"
              >Website ↗</a>
              <a
                href="https://zenodo.org/communities/cornerstone-data/records?q=&l=list&p=1&s=10&sort=newest"
                class="text-ink-2 hover:text-ink border-b-0"
                target="_blank"
                rel="noopener"
              >Zenodo ↗</a>
              <a
                href="https://github.com/cornerstone-data"
                class="text-ink-2 hover:text-ink border-b-0"
                target="_blank"
                rel="noopener"
              >GitHub ↗</a>
            </div>
          </div>
        </article>
      </li>

      {cards.map((t) => (
        <li class="m-0 p-0">
          <a
            href={t.href}
            class="block bg-paper border border-rule hover:border-ink-3 transition-colors border-b-0"
            style="border-radius: var(--radius-md); overflow: hidden;"
            data-external={t.isExternal ? '' : null}
          >
            {t.imgUrl && (
              <img
                src={t.imgUrl}
                alt={t.title}
                loading="lazy"
                class="block w-full object-cover"
                style="aspect-ratio: 16/10;"
              />
            )}
            <div class="p-6">
              {t.eyebrow && <p class="eyebrow m-0 mb-2">{t.eyebrow}</p>}
              <h3 class="m-0">{t.title}</h3>
              {t.summary && (
                <p class="text-ink-2 text-sm mt-2 m-0">{t.summary}</p>
              )}
              {t.companion && (
                <p class="font-mono text-xs text-ink-3 mt-3 m-0 uppercase tracking-wider">
                  Companion paper · <em class="not-italic">{t.companion.journal}</em> · {t.companion.year}
                </p>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

    {cards.length === 0 && (
      <p class="text-ink-3 text-sm">No tools yet — add a row to the Tools sheet.</p>
    )}
  </section>
</BaseLayout>
