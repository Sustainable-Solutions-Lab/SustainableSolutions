---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Explorer from '../../tools/_engine/Explorer';
import { materialsConfig } from '../../tools/materials/config';
import tools from '../../data/tools.json';
import type { Tool } from '../../lib/types';

const tool = (tools as Tool[]).find((t) => t.slug === 'materials') ?? null;
---

<BaseLayout
  title={tool?.title ?? materialsConfig.title}
  description={tool?.summary ?? materialsConfig.description}
  hideFooter={true}
  noindex
>
  <section aria-label="Materials explorer">
    <div class="materials-frame">
      <Explorer client:only="react" config={materialsConfig} />
    </div>
  </section>
</BaseLayout>

<style is:global>
  body:has(.materials-frame) { overflow: hidden; }
  .materials-frame {
    position: relative;
    width: 100%;
    height: calc(100vh - 56px);
    height: calc(100dvh - 56px);
    background: var(--paper);
    overflow: hidden;
  }
  .materials-frame > * { width: 100%; height: 100%; }
</style>
