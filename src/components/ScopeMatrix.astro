---
// Compact lab-scope heatmap.
//
// 6×4 grid of small colored squares — rows = human systems (energy,
// food, water, land, materials, fire), columns = problem types
// (emissions, impacts, air pollution, heat). Color comes from the
// lab's ColorBrewer Spectral palette, scaled by count. Labels are
// hover-only; the visual sits next to the hero lede as a small
// orientation glyph rather than a fully-labeled chart.
//
// Multi-tagged papers contribute to every matching cell, so the
// matrix shows breadth of focus rather than a strict partition.

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const SYSTEMS = ['energy', 'food', 'water', 'land', 'materials', 'fire'] as const;
const PROBLEMS = ['emissions', 'impacts', 'air pollution', 'heat'] as const;

const SYSTEM_LABEL: Record<string, string> = {
  energy: 'Energy',
  food: 'Food',
  water: 'Water',
  land: 'Land',
  materials: 'Materials',
  fire: 'Fire',
};
const PROBLEM_LABEL: Record<string, string> = {
  emissions: 'Emissions',
  impacts: 'Impacts',
  'air pollution': 'Air pollution',
  heat: 'Heat',
};

const pubs = publications as Publication[];

const cellPapers = new Map<string, number>();
for (const p of pubs) {
  const themes = (p.themes ?? []) as string[];
  const sys = themes.filter((t) => (SYSTEMS as readonly string[]).includes(t));
  const prob = themes.filter((t) => (PROBLEMS as readonly string[]).includes(t));
  for (const s of sys) {
    for (const pr of prob) {
      const k = `${s}|${pr}`;
      cellPapers.set(k, (cellPapers.get(k) ?? 0) + 1);
    }
  }
}

let maxCell = 0;
for (const v of cellPapers.values()) if (v > maxCell) maxCell = v;

// Map count → Spectral palette index (1..11). Reverse the palette so
// high counts read as cool/dark (purple) and low counts as warm/light
// (red-orange), matching scientific-viz convention for sequential data.
function spectralVar(count: number): string {
  if (!maxCell || !count) return 'transparent';
  const t = count / maxCell;       // 0..1
  // Map t into 11 bins; reverse so low count = spectral-2, high = spectral-10.
  const idx = Math.max(2, Math.min(10, Math.round(2 + t * 8)));
  return `var(--spectral-${idx})`;
}
---

<div class="scope-matrix-mini" aria-label="Scope of lab publications by human-system theme and problem type">
  {SYSTEMS.flatMap((s) =>
    PROBLEMS.map((p) => {
      const count = cellPapers.get(`${s}|${p}`) ?? 0;
      return (
        <div
          class="scope-cell-mini"
          style={`background-color: ${spectralVar(count)};`}
          title={`${SYSTEM_LABEL[s]} × ${PROBLEM_LABEL[p]} · ${count} paper${count === 1 ? '' : 's'}`}
        ></div>
      );
    }),
  )}
</div>

<style>
  .scope-matrix-mini {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(6, 1fr);
    gap: 2px;
    padding: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    /* Compact size — sits beside the hero lede as a glyph, not a chart. */
    width: 140px;
    aspect-ratio: 4 / 6;
    flex: none;
  }
  .scope-cell-mini {
    background: var(--paper);
    transition: outline 0.12s ease;
  }
  .scope-cell-mini:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }
</style>
