---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PublicationItem from '../../components/PublicationItem.astro'
import people from '../../data/people.json'
import publications from '../../data/publications.json'
import type { Person, Publication } from '../../lib/types'
import { splitAndLinkAuthors } from '../../lib/author-links'
import scholarDetails from '../../../templates/scholar-details.json'

export async function getStaticPaths() {
  const { default: people } = await import('../../data/people.json')
  return (people as Person[]).map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }))
}

const { person } = Astro.props as { person: Person }

const peopleArr = people as Person[]
const personPubs = (publications as Publication[])
  .filter((p) =>
    splitAndLinkAuthors(p.authors ?? '', peopleArr).some((s) => s.slug === person.slug),
  )
  .sort((a, b) => b.year - a.year || (b.month ?? 0) - (a.month ?? 0))

// Build a {DOI → total_citations} lookup for picking "most cited" papers.
const totalsByDoi = new Map<string, number>()
for (const detail of Object.values(scholarDetails as Record<string, any>)) {
  if (detail?.doi && typeof detail?.total_citations === 'number') {
    totalsByDoi.set(detail.doi, detail.total_citations)
  }
}

// Featured 4: 2 most recent + 2 most cited (deduped). Falls back to fewer
// if the person has fewer than 4 pubs total.
const recent = personPubs.slice(0, 2)
const byCitations = [...personPubs].sort((a, b) => {
  const aCit = (a.doi && totalsByDoi.get(a.doi)) ?? 0
  const bCit = (b.doi && totalsByDoi.get(b.doi)) ?? 0
  return bCit - aCit
})
const featuredPubs: Publication[] = [...recent]
for (const p of byCitations) {
  if (featuredPubs.length >= 4) break
  if (!featuredPubs.some((f) => f.doi === p.doi && p.doi)) featuredPubs.push(p)
  else if (!featuredPubs.includes(p)) featuredPubs.push(p)
}
const displayPubs = featuredPubs.slice(0, 4)
const hasMorePubs = personPubs.length > displayPubs.length

// Optional Markdown bio: src/content/people/<slug>.md
let BioContent: any = null
const peopleEntries = await getCollection('people')
const bioEntry = peopleEntries.find((e) => e.id === person.slug)
if (bioEntry) {
  const rendered = await render(bioEntry)
  BioContent = rendered.Content
}

const dateRange = person.left_date
  ? `${person.joined_date ?? '?'} through ${person.left_date}`
  : person.joined_date
    ? `Since ${person.joined_date}`
    : null

// Split current_position on first comma into institution + role.
const cp = person.current_position ?? ''
const commaIdx = cp.indexOf(',')
const currentInstitution = commaIdx === -1 ? cp.trim() : cp.slice(0, commaIdx).trim()
const currentRole = commaIdx === -1 ? '' : cp.slice(commaIdx + 1).trim()

const sectionLabel =
  person.status === 'alumni' ? 'ALUMNI'
  : person.unit === 'ciu' ? 'CONCEPTUAL INVESTIGATIONS UNIT'
  : 'CURRENT'

// Spectral letter-avatar fallback (mirrors PersonCard logic for a consistent feel)
const spectralColors = [
  'var(--spectral-2)', 'var(--spectral-3)', 'var(--spectral-4)',
  'var(--spectral-9)', 'var(--spectral-10)', 'var(--spectral-11)',
]
const hash = [...person.slug].reduce((a, c) => a + c.charCodeAt(0), 0)
const avatarBg = spectralColors[hash % spectralColors.length]
const initials = person.name
  .split(/\s+/)
  .filter((s: string) => /^[A-Z]/.test(s) && s.length > 1)
  .slice(0, 2)
  .map((s: string) => s[0])
  .join('')
---

<BaseLayout title={person.name}>
  <article class="container-prose py-16">
    <div class="flex flex-col sm:flex-row items-start gap-6 mb-10">
      {
        person.photo_filename ? (
          <img
            src={`/people/${person.photo_filename}`}
            alt={person.name}
            width="144"
            height="144"
            class="shrink-0 object-cover border border-rule"
            style="width: 144px; height: 144px; border-radius: var(--radius-md);"
          />
        ) : (
          <div
            aria-hidden="true"
            class="shrink-0 flex items-center justify-center font-mono text-4xl text-paper select-none"
            style={`width: 144px; height: 144px; background: ${avatarBg}; border-radius: var(--radius-md);`}
          >
            {initials || '·'}
          </div>
        )
      }
      <div class="flex-1 min-w-0">
        <p class="eyebrow mb-3">
          <span class="cardinal-dot"></span>{sectionLabel}
        </p>
        <h1 class="m-0">{person.name}</h1>
        <p class="lede mt-2 m-0">{person.role}</p>
      </div>
    </div>

    {
      person.bio_short && !BioContent && (
        <p class="mt-6">{person.bio_short}</p>
      )
    }

    {
      BioContent && (
        <div class="mt-8 prose-content">
          <BioContent />
        </div>
      )
    }

    <dl class="mt-10 grid grid-cols-[max-content_1fr] gap-x-6 gap-y-2 text-sm">
      {
        currentInstitution && (
          <>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-3">Currently</dt>
            <dd class="m-0" style="line-height: 1.15;">
              {currentInstitution}{currentRole ? ',' : ''}
              {currentRole && (<><br />{currentRole}</>)}
            </dd>
          </>
        )
      }
      {
        dateRange && (
          <>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-3">In the lab</dt>
            <dd class="m-0">{dateRange}</dd>
          </>
        )
      }
      {
        person.personal_url && (
          <>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-3">Site</dt>
            <dd class="m-0">
              <a href={person.personal_url} data-external>{person.personal_url.replace(/^https?:\/\//, '')}</a>
            </dd>
          </>
        )
      }
    </dl>

    {
      displayPubs.length > 0 && (
        <section class="mt-16">
          <p class="eyebrow mb-4">
            PUBLICATIONS
            {personPubs.length > displayPubs.length && (
              <span class="text-ink-3"> · {displayPubs.length} of {personPubs.length}</span>
            )}
          </p>
          <ul class="list-none p-0 m-0">
            {displayPubs.map((pub) => <PublicationItem pub={pub} />)}
          </ul>
          {
            hasMorePubs && (
              <p class="mt-6">
                <a href={`/publications?author=${person.slug}`} class="font-mono text-xs uppercase tracking-wider">
                  See all {personPubs.length} publications →
                </a>
              </p>
            )
          }
        </section>
      )
    }

    <p class="mt-12">
      <a href="/people" class="font-mono text-xs uppercase tracking-wider">← Back to People</a>
    </p>
  </article>
</BaseLayout>

<style>
  /* Markdown content renders inside .prose-content — light typography
     overrides for headings/paragraphs/lists when a bio.md is present. */
  .prose-content :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--t-xl);
    font-weight: 500;
    line-height: var(--lh-snug);
    margin: var(--s-6) 0 var(--s-3);
  }
  .prose-content :global(h3) {
    font-family: var(--font-sans);
    font-size: var(--t-md);
    font-weight: 600;
    margin: var(--s-5) 0 var(--s-2);
  }
  .prose-content :global(p) {
    margin: 0 0 var(--s-4);
  }
  .prose-content :global(ul) {
    padding-left: var(--s-5);
    margin: 0 0 var(--s-4);
  }
  .prose-content :global(li) {
    margin-bottom: var(--s-2);
  }
</style>
