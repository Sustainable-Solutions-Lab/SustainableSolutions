---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import publications from '../data/publications.json';
import people from '../data/people.json';
import type { Publication, Person } from '../lib/types';
import { splitAndLinkAuthors } from '../lib/author-links';
import { ROLE_COLORS } from '../lib/roles';

const all = (publications as Publication[])
  .slice()
  .sort((a, b) => b.year - a.year || (b.month ?? 0) - (a.month ?? 0));

const years = [...new Set(all.map((p) => p.year).filter((y): y is number => typeof y === 'number' && !!y))].sort((a, b) => b - a);

// Two-axis filter taxonomy mirroring the home-page scope matrix.
// System options are top-level only; sub-system tags (e.g. energy:electricity)
// are folded in via prefix matching, so a paper tagged energy:electricity
// is found by selecting "Energy". Topic options are grouped by section, with
// a roll-up "(all)" entry that prefix-matches every sub-topic.
const SYSTEM_OPTIONS = [
  { value: 'energy',    label: 'Energy'    },
  { value: 'food',      label: 'Food'      },
  { value: 'water',     label: 'Water'     },
  { value: 'materials', label: 'Materials' },
  { value: 'climate',   label: 'Climate'   },
  { value: 'health',    label: 'Health'    },
];

const TOPIC_GROUPS = [
  {
    label: 'Mitigation',
    options: [
      { value: 'mitigation',                   label: 'Mitigation (all)' },
      { value: 'mitigation:trade',             label: 'Trade' },
      { value: 'mitigation:carbon-management', label: 'Carbon management' },
    ],
  },
  {
    label: 'Impacts & adaptation',
    options: [
      { value: 'impacts',               label: 'Impacts (all)' },
      { value: 'impacts:air-pollution', label: 'Air pollution' },
      { value: 'impacts:heat',          label: 'Heat' },
      { value: 'impacts:drought',       label: 'Drought' },
      { value: 'impacts:fire',          label: 'Fire' },
      { value: 'impacts:flooding',      label: 'Flooding' },
    ],
  },
];

// Lab-author filter options: any lab member detected in at least one
// publication's authors string. Auto-derived from author-name matching so
// the Sheet's lab_authors column is no longer required to populate this.
const peopleArr = people as Person[];
const detectedSlugs = new Set<string>();
for (const pub of all) {
  for (const seg of splitAndLinkAuthors(pub.authors ?? '', peopleArr)) {
    if (seg.slug) detectedSlugs.add(seg.slug);
  }
}
const labAuthorOptions = peopleArr
  .filter((p) => detectedSlugs.has(p.slug))
  .sort((a, b) => a.name.localeCompare(b.name));

const total = all.length;
---

<BaseLayout title="Publications">
  <section class="container-content pt-8 pb-8">
    <p class="eyebrow mb-4">PUBLICATIONS</p>
    <h1>Peer-reviewed work</h1>
    <p class="lede max-w-prose mt-4">
      Reverse chronological. Filter by theme, year, or featured status; search
      across titles, authors, and journals.
    </p>
  </section>

  <section class="container-content pb-24">
    <div
      class="flex flex-wrap items-center gap-2 md:gap-4 py-2 md:py-4 mb-2 border-y border-rule bg-paper sticky z-20"
      style="top: 56px;"
      role="search"
    >
      <label class="flex items-center gap-2 text-sm flex-1 md:flex-initial min-w-0">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Search</span>
        <input
          id="pub-search"
          type="search"
          placeholder="Search…"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink w-full md:w-auto"
          style="border-radius: var(--radius-sm); min-width: 0; md:min-width: 16ch;"
        />
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Year</span>
        <select
          id="pub-year"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All years</option>
          {years.map((y) => <option value={y}>{y}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">System</span>
        <select
          id="pub-system"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All systems</option>
          {SYSTEM_OPTIONS.map((s) => <option value={s.value}>{s.label}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Topic</span>
        <select
          id="pub-topic"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All topics</option>
          {TOPIC_GROUPS.map((g) => (
            <optgroup label={g.label}>
              {g.options.map((o) => <option value={o.value}>{o.label}</option>)}
            </optgroup>
          ))}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Approach</span>
        <select
          id="pub-approach"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All approaches</option>
          <option value="conceptual">Conceptual</option>
          <option value="data-driven">Data-driven</option>
        </select>
      </label>

      {labAuthorOptions.length > 0 && (
        <label class="flex items-center gap-2 text-sm">
          <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Author</span>
          <select
            id="pub-author"
            class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
            style="border-radius: var(--radius-sm);"
          >
            <option value="">All authors</option>
            {labAuthorOptions.map((p) => <option value={p.slug}>{p.name}</option>)}
          </select>
        </label>
      )}

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Sort</span>
        <select
          id="pub-sort"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="date">Most recent</option>
          <option value="total-citations">Total citations</option>
          <option value="citations-per-year">Citations / year</option>
          <option value="recent-citations">Recent citations (3 yr)</option>
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <input id="pub-featured" type="checkbox" class="accent-cardinal" />
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Featured</span>
      </label>

      <span class="ml-auto font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">
        Roles:
        <span style={`color: ${ROLE_COLORS.student}; font-weight: 600;`}>Student</span>
        <span class="dot">·</span>
        <span style={`color: ${ROLE_COLORS.postdoc}; font-weight: 600;`}>Postdoc</span>
        <span class="dot">·</span>
        <span style={`color: ${ROLE_COLORS.staff}; font-weight: 600;`}>Staff</span>
      </span>

      <span id="pub-count" class="font-mono text-xs text-ink-3 ml-auto md:ml-4">
        {total} of {total}
      </span>
    </div>

    <ul id="pub-list" class="list-none p-0 m-0">
      {all.map((pub) => <PublicationItem pub={pub} />)}
    </ul>

    <p id="pub-empty" hidden class="py-12 text-center text-ink-3 text-sm">
      No publications match the current filters.
    </p>
  </section>
</BaseLayout>

{/* Altmetric + Dimensions badge embeds — read data-doi attributes
    rendered into featured publication cards. Loaded only on this page. */}
<script async src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"></script>
<script async src="https://badge.dimensions.ai/badge.js" charset="utf-8"></script>

<script is:inline>
  (function () {
    const search = document.getElementById('pub-search');
    const yearSel = document.getElementById('pub-year');
    const systemSel = document.getElementById('pub-system');
    const topicSel = document.getElementById('pub-topic');
    const approachSel = document.getElementById('pub-approach');
    const authorSel = document.getElementById('pub-author');
    const sortSel = document.getElementById('pub-sort');
    const feat = document.getElementById('pub-featured');
    const list = document.getElementById('pub-list');
    const empty = document.getElementById('pub-empty');
    const count = document.getElementById('pub-count');
    if (!list || !count) return;

    const items = Array.from(list.querySelectorAll('[data-pub]'));
    const total = items.length;

    const sortKey = (li) => {
      const k = sortSel?.value ?? 'date';
      if (k === 'date') {
        return -(parseInt(li.dataset.year || '0', 10) * 100 + parseInt(li.dataset.month || '0', 10));
      }
      if (k === 'total-citations')      return -parseFloat(li.dataset.totalCitations || '0');
      if (k === 'citations-per-year')   return -parseFloat(li.dataset.citationsPerYear || '0');
      if (k === 'recent-citations')     return -parseFloat(li.dataset.recentCitations || '0');
      return 0;
    };

    const applySort = () => {
      const sorted = [...items].sort((a, b) => sortKey(a) - sortKey(b));
      for (const li of sorted) list.appendChild(li);
    };

    // System and Topic dropdowns use prefix matching so System=energy
    // catches energy:electricity, Topic=mitigation catches mitigation:trade,
    // etc. The matrix-cell links target ?system=…&response=… and the page
    // pre-selects both dropdowns from those params on load.
    function axisHasPrefix(values, target) {
      if (!target) return true;
      for (const v of values) {
        if (!v) continue;
        if (v === target) return true;
        if (v.startsWith(target + ':')) return true;
      }
      return false;
    }

    const apply = () => {
      const q = (search?.value ?? '').trim().toLowerCase();
      const y = yearSel?.value ?? '';
      const sys = systemSel?.value ?? '';
      const top = topicSel?.value ?? '';
      const ap = approachSel?.value ?? '';
      // Approach filter values match the dropdown option values: 'conceptual'
      // matches data-conceptual="true"; 'data-driven' matches "false".
      const a = authorSel?.value ?? '';
      const f = feat?.checked ?? false;

      let visible = 0;
      for (const li of items) {
        const sysVals = (li.dataset.system ?? '').split(',').filter(Boolean);
        const respVals = (li.dataset.response ?? '').split(',').filter(Boolean);
        const labAuthors = (li.dataset.labAuthors ?? '').split(',').filter(Boolean);
        const conceptual = li.dataset.conceptual === 'true';
        const okApproach =
          !ap ||
          (ap === 'conceptual' && conceptual) ||
          (ap === 'data-driven' && !conceptual);
        const ok =
          (!q || (li.dataset.search ?? '').includes(q)) &&
          (!y || li.dataset.year === y) &&
          (!a || labAuthors.includes(a)) &&
          (!f || li.dataset.featured === 'true') &&
          okApproach &&
          axisHasPrefix(sysVals, sys) &&
          axisHasPrefix(respVals, top);
        li.hidden = !ok;
        if (ok) visible++;
      }

      count.textContent = `${visible} of ${total}`;
      if (empty) empty.hidden = visible !== 0;
    };

    // Pre-fill dropdowns from URL params:
    //   ?author=<slug>     used by the "see all" link on people detail pages
    //   ?sort=<key>        deep-link to a particular sort
    //   ?system=<key>      set by clicking a scope-matrix cell on the home page
    //   ?response=<value>  set by clicking a scope-matrix cell (topic axis)
    // The matrix-cell links land here with both system and response set, so
    // the System and Topic selects come up pre-selected for the clicked
    // intersection — no separate focus banner.
    const params = new URLSearchParams(window.location.search);
    const setSelectIfPresent = (sel, value) => {
      if (!sel || !value) return;
      const opt = Array.from(sel.options).find((o) => o.value === value);
      if (opt) sel.value = value;
    };
    setSelectIfPresent(authorSel,    params.get('author'));
    setSelectIfPresent(sortSel,      params.get('sort'));
    setSelectIfPresent(systemSel,    (params.get('system') ?? '').trim());
    setSelectIfPresent(topicSel,     (params.get('response') ?? '').trim());
    // ?approach=conceptual|data-driven. Legacy aliases: ?ciu=true|false and
    // ?approach=ciu|non-ciu both map to the new values for backward-compat.
    const rawApproach = params.get('approach') ?? '';
    const ciuParam = params.get('ciu');
    const approachParam =
      rawApproach === 'ciu' ? 'conceptual' :
      rawApproach === 'non-ciu' ? 'data-driven' :
      rawApproach ||
      (ciuParam === 'true' ? 'conceptual' :
       ciuParam === 'false' ? 'data-driven' : null);
    setSelectIfPresent(approachSel, approachParam);

    [search, yearSel, systemSel, topicSel, approachSel, authorSel, feat].forEach((el) => {
      el?.addEventListener('input', apply);
      el?.addEventListener('change', apply);
    });
    sortSel?.addEventListener('change', applySort);

    applySort();
    apply();
  })();
</script>
