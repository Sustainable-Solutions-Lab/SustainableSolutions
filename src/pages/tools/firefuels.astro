---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Firefuels from '../../tools/firefuels/Firefuels.jsx';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';

const tool = (tools as Tool[]).find((t) => t.slug === 'firefuels') ?? null;
const companion = tool?.doi
  ? (publications as Publication[]).find((p) => p.doi?.toLowerCase() === tool.doi!.toLowerCase()) ?? null
  : null;
const companionUrl = companion?.url ?? (companion?.doi ? `https://doi.org/${companion.doi}` : null);
---

<BaseLayout
  title={tool?.title ?? 'Firefuels'}
  description={tool?.summary}
  hideFooter={true}
>
  {companion && (
    <div class="container-content pt-3 pb-2">
      <p class="font-mono text-xs text-ink-3 m-0 uppercase tracking-wider">
        Companion paper ·
        {companionUrl ? (
          <a href={companionUrl} class="text-ink-2 hover:text-ink border-b-0" data-external>
            <em class="not-italic">{companion.journal}</em> · {companion.year}
          </a>
        ) : (
          <span><em class="not-italic">{companion.journal}</em> · {companion.year}</span>
        )}
      </p>
    </div>
  )}

  <section aria-label="Interactive map">
    <div
      class="firefuels-frame border-t border-rule"
      style="width: 100%; overflow: hidden; background: var(--paper-2);"
    >
      <Firefuels client:only="react" />
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Map fills the viewport from where it starts down to the bottom edge.
     Subtracts the sticky nav (56 px) and the companion-paper strip (~36 px)
     so the page ends precisely at the map's bottom. The body itself
     doesn't scroll on this page; the map sidebar has its own scroll. */
  body:has(.firefuels-frame) { overflow: hidden; }
  .firefuels-frame { position: relative; height: calc(100vh - 92px); }
  .firefuels-frame > * { width: 100%; height: 100%; }
</style>
