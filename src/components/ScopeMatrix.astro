---
// Lab-scope heatmap, reference-style.
//
// Columns = systems       (Energy · Food · Water · Materials · Climate · Health)
// Rows    = response type, two sections separated by a section header:
//             MITIGATION:  General · Trade · Carbon mgmt
//             IMPACTS &
//             ADAPTATION:  General · Air pollution · Heat · Drought · Fire · Flooding
//
// Cell color is mapped from the paper count via the lab's full
// ColorBrewer Spectral palette: low counts at the cool/green end,
// high counts at the warm/red end, no-papers cells stay paper.
// Single global scale (max count anywhere) so absolute density reads
// across the whole figure.
//
// Sub-tag rollup: system=energy:electricity → Energy column, response=
// impacts:drought → Drought row, etc. (prefix match).

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const SYSTEMS = [
  { key: 'energy',    label: 'Energy'    },
  { key: 'food',      label: 'Food'      },
  { key: 'water',     label: 'Water'     },
  { key: 'materials', label: 'Materials' },
  { key: 'climate',   label: 'Climate'   },
  { key: 'health',    label: 'Health'    },
] as const;

const MIT_ROWS = [
  { key: 'general',           label: 'General',     match: 'mitigation' },
  { key: 'trade',             label: 'Trade',       match: 'mitigation:trade' },
  { key: 'carbon-management', label: 'Carbon mgmt', match: 'mitigation:carbon-management' },
] as const;

const IMP_ROWS = [
  { key: 'general',       label: 'General',       match: 'impacts' },
  { key: 'air-pollution', label: 'Air pollution', match: 'impacts:air-pollution' },
  { key: 'heat',          label: 'Heat',          match: 'impacts:heat' },
  { key: 'drought',       label: 'Drought',       match: 'impacts:drought' },
  { key: 'fire',          label: 'Fire',          match: 'impacts:fire' },
  { key: 'flooding',      label: 'Flooding',      match: 'impacts:flooding' },
] as const;

const pubs = publications as Publication[];

function axisMatches(values: string[], target: string): boolean {
  for (const v of values) {
    if (v === target) return true;
    if (v.startsWith(target + ':')) return true;
  }
  return false;
}

const cellCount: Record<string, number> = {};
let globalMax = 0;
for (const sys of SYSTEMS) {
  for (const row of [...MIT_ROWS, ...IMP_ROWS]) {
    let n = 0;
    for (const p of pubs) {
      const s = (p.system ?? []) as string[];
      const r = (p.response ?? []) as string[];
      if (axisMatches(s, sys.key) && axisMatches(r, row.match)) n++;
    }
    cellCount[`${sys.key}|${row.key}`] = n;
    if (n > globalMax) globalMax = n;
  }
}

// Sequential Spectral ramp keyed off paper count. Empty cells stay
// paper-toned (faint, distinct from the data). Counts ramp through the
// cool-to-warm Spectral spread: low = blue/green end, high = red/wine.
function cellBg(count: number): string {
  if (!count) return 'var(--paper-2)';
  const t = count / globalMax;
  // Interpolate idx from 10 (blue, low) → 2 (red, high) across all 9
  // ramp positions. Bias the curve so even count=1 lands in the green
  // band (visible) rather than the very-pale yellow.
  const idx = Math.max(2, Math.min(10, Math.round(10 - t * 8)));
  return `var(--spectral-${idx})`;
}
---

<figure class="scope-figure">
  <p class="scope-eyebrow">
    <span class="cardinal-dot"></span>FIGURE · LAB SCOPE
  </p>
  <h3 class="scope-headline">Where the lab works</h3>
  <p class="scope-subtitle">
    <em>Publications by system × response</em>
  </p>

  <div class="scope-grid">
    {/* Column headers — system labels (Inter, title case, no wrap) */}
    <div></div>
    {SYSTEMS.map((s) => (
      <div class="col-label">{s.label}</div>
    ))}

    {/* Mitigation section header */}
    <div class="section-label section-mit">Mitigation</div>

    {MIT_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(count)};`}
              title={`${s.label} × Mitigation: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </>
    ))}

    {/* Impacts section header */}
    <div class="section-label section-imp">Impacts &amp; Adaptation</div>

    {IMP_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(count)};`}
              title={`${s.label} × Impacts: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </>
    ))}
  </div>

  <figcaption class="scope-caption">
    <em>
      Diverging Spectral palette: cells warm from green/blue (few papers
      tagged with that system × response) toward red/wine (most papers).
      Hover for counts.
    </em>
  </figcaption>
</figure>

<style>
  .scope-figure {
    margin: 0;
    width: 100%;
  }
  .scope-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cardinal);
    margin: 0 0 6px;
  }
  .scope-headline {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .scope-subtitle {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 14px;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: minmax(80px, max-content) repeat(6, minmax(46px, 1fr));
    gap: 3px;
    align-items: stretch;
  }

  /* Column headers (sans-serif title case, no wrap, more reading-friendly
     than uppercase mono at this size). */
  .col-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-align: center;
    color: var(--ink-2);
    padding: 0 0 4px;
    white-space: nowrap;
    align-self: end;
  }

  .section-label {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 6px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--rule);
  }
  .section-mit { color: var(--spectral-10); }
  .section-imp { color: var(--spectral-2); }

  .row-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-2);
    text-align: right;
    padding-right: 8px;
    align-self: center;
    white-space: nowrap;
  }

  .cell {
    background: var(--paper-2);
    border-radius: 3px;
    height: 22px;
    transition: outline 0.12s ease;
  }
  .cell:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }

  .scope-caption {
    margin: 14px 0 0;
    font-family: var(--font-serif);
    font-size: 12px;
    line-height: 1.5;
    color: var(--ink-3);
    max-width: 38ch;
  }
</style>
