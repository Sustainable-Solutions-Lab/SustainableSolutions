---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MapTool from '../../tools/map/MapTool.jsx';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';

const tool = (tools as Tool[]).find((t) => t.slug === 'firefuels') ?? null;
const companionPub = tool?.doi
  ? (publications as Publication[]).find((p) => p.doi?.toLowerCase() === tool.doi!.toLowerCase()) ?? null
  : null;
// Hand-pin the preprint URL for firefuels so the companion link goes
// straight to the EarthArxiv preprint page instead of bouncing through
// doi.org. (The publication row's url is the doi.org redirect, which
// works but adds an extra hop on click.)
const FIREFUELS_PREPRINT_URL = 'https://eartharxiv.org/repository/view/9858/';
const companion = companionPub
  ? {
      title: companionPub.title,
      journal: companionPub.journal,
      year: companionPub.year,
      url: FIREFUELS_PREPRINT_URL,
    }
  : null;
---

<BaseLayout
  title={tool?.title ?? 'Firefuels'}
  description={tool?.summary}
  hideFooter={true}
>
  <section aria-label="Interactive map">
    <div
      class="firefuels-frame"
      style="width: 100%; overflow: hidden; background: var(--paper-2);"
    >
      <MapTool
        client:only="react"
        companion={companion}
        display={tool ? { title: tool.title, eyebrow: tool.eyebrow, summary: tool.summary } : null}
      />
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Map fills the viewport from below the sticky nav (56 px) to the bottom
     edge — companion paper info now lives in the sidebar's footer area
     instead of as a strip above the map. The body itself doesn't scroll
     on this page; the sidebar inside the map keeps its own internal scroll. */
  body:has(.firefuels-frame) { overflow: hidden; }
  .firefuels-frame {
    position: relative;
    height: calc(100vh - 56px);
    /* dvh tracks the actually-visible viewport on iOS Safari (excludes the
       URL bar when it slides into view), so the map's color bar and in-map
       controls don't end up hidden behind browser chrome. */
    height: calc(100dvh - 56px);
  }
  .firefuels-frame > * { width: 100%; height: 100%; }
</style>
