---
import type { Person, Publication, Tool } from '../lib/types';
import { roleColor } from '../lib/roles';
import { splitAndLinkAuthors } from '../lib/author-links';
import publications from '../data/publications.json';
import externalPubs from '../data/external-pubs.json';
import tools from '../data/tools.json';
import scholarDetails from '../../templates/scholar-details.json';

interface Props {
  person: Person;
}

const { person } = Astro.props;
const detailHref = `/people/${person.slug}`;
const sectionLabel =
  person.unit === 'ciu' ? 'CONCEPTUAL INVESTIGATIONS UNIT' : 'CURRENT';
const stripeColor = roleColor(person.role);

// Spectral letter-avatar fallback (same hash as PersonCard for visual continuity)
const spectralColors = [
  'var(--spectral-2)', 'var(--spectral-3)', 'var(--spectral-4)',
  'var(--spectral-9)', 'var(--spectral-10)', 'var(--spectral-11)',
];
const hash = [...person.slug].reduce((a, c) => a + c.charCodeAt(0), 0);
const avatarBg = spectralColors[hash % spectralColors.length];
const initials = person.name
  .split(/\s+/)
  .filter((s) => /^[A-Z]/.test(s) && s.length > 1)
  .slice(0, 2)
  .map((s) => s[0])
  .join('');

const orcidUrl = person.orcid ? `https://orcid.org/${person.orcid}` : null;

// Notable + Recent work — sheet-driven by DOI, with fallbacks.
//
//   notable_pub_doi  → resolve from the person's matched papers; else the
//                      person's most-cited paper (Scholar total_citations).
//   recent_pub_doi   → resolve similarly; else the person's most-recent paper
//                      (year then month, descending).
//
// If both columns resolve to the same paper (e.g., one DOI set, the other
// fallback picks the same one), Recent is hidden so we don't duplicate.
const totalsByDoi = new Map<string, number>();
for (const detail of Object.values(scholarDetails as Record<string, any>)) {
  if (detail?.doi && typeof detail?.total_citations === 'number') {
    totalsByDoi.set(detail.doi, detail.total_citations);
  }
}
// Crossref-fetched external pubs include their own citation counts; fold
// those in too so Notable/Recent cards from pre-lab work show "X citations".
for (const ext of externalPubs as Array<{ doi: string; total_citations: number | null }>) {
  if (ext.doi && typeof ext.total_citations === 'number') {
    totalsByDoi.set(ext.doi, ext.total_citations);
  }
}

const personPubs = (publications as Publication[]).filter((p) =>
  splitAndLinkAuthors(p.authors ?? '', [person]).some((s) => s.slug === person.slug),
);
const personPubsByDoi = new Map<string, Publication>();
for (const p of personPubs) if (p.doi) personPubsByDoi.set(p.doi.toLowerCase(), p);
// External pubs are keyed only by DOI — they're papers from before the
// person joined the lab (or otherwise outside the Publications sheet) and
// shouldn't be matched by author detection.
const externalByDoi = new Map<string, Publication>();
for (const ext of externalPubs as Publication[]) {
  if (ext.doi) externalByDoi.set(ext.doi.toLowerCase(), ext);
}

function resolveExplicit(doi: string | null): Publication | null {
  if (!doi) return null;
  const k = doi.trim().toLowerCase();
  return personPubsByDoi.get(k) ?? externalByDoi.get(k) ?? null;
}
const mostCited = [...personPubs].sort((a, b) => {
  const aC = (a.doi && totalsByDoi.get(a.doi)) ?? 0;
  const bC = (b.doi && totalsByDoi.get(b.doi)) ?? 0;
  return bC - aC;
})[0] ?? null;
const mostRecent = [...personPubs].sort((a, b) =>
  (b.year - a.year) || ((b.month ?? 0) - (a.month ?? 0)),
)[0] ?? null;

// Tool reference support: a People-sheet cell of the form `tool:<slug>`
// surfaces a Tools-tab entry (e.g. tool:cornerstone) in the Notable or
// Recent slot, alongside the existing DOI-based publication path.
const toolsBySlug = new Map<string, Tool>();
for (const t of tools as Tool[]) toolsBySlug.set(t.slug, t);
// Slugs whose own /tools/<slug> page isn't generated (multi-link
// initiatives etc.) — fall back to /tools for the work link.
const TOOLS_WITHOUT_DETAIL_PAGE = new Set(['cornerstone']);

function resolveTool(value: string | null): Tool | null {
  if (!value) return null;
  const m = value.trim().match(/^tool:(.+)$/i);
  if (!m) return null;
  return toolsBySlug.get(m[1].trim()) ?? null;
}
function toolUrl(t: Tool): string {
  if (t.link) return t.link;
  if (TOOLS_WITHOUT_DETAIL_PAGE.has(t.slug)) return '/tools';
  return `/tools/${t.slug}`;
}
function toolMetaLine(t: Tool): string {
  if (!t.eyebrow) return '';
  // "OPEN DATA INITIATIVE" → "Open data initiative" for the mono caption.
  return t.eyebrow.charAt(0).toUpperCase() + t.eyebrow.slice(1).toLowerCase();
}

const notableTool = resolveTool(person.notable_pub_doi);
const recentTool = resolveTool(person.recent_pub_doi);

const notable: Publication | null = notableTool
  ? null
  : (resolveExplicit(person.notable_pub_doi) ?? mostCited);
let recent: Publication | null = recentTool
  ? null
  : (resolveExplicit(person.recent_pub_doi) ?? mostRecent);
if (recent && notable && recent.doi && notable.doi && recent.doi === notable.doi) {
  recent = null;
}

function pubMeta(pub: Publication) {
  const citations = pub.doi ? totalsByDoi.get(pub.doi) ?? null : null;
  const url = pub.url ?? (pub.doi ? `https://doi.org/${pub.doi}` : null);
  return { citations, url };
}
const notableMeta = notable ? pubMeta(notable) : null;
const recentMeta = recent ? pubMeta(recent) : null;
---

<article
  class="grid md:grid-cols-[1fr_240px] gap-6 p-6 border border-rule bg-paper"
  style={`border-radius: var(--radius-md); border-left: 4px solid ${stripeColor};`}
>
  <div class="min-w-0">
    <p class="eyebrow m-0 mb-2">
      <span class="cardinal-dot"></span>{sectionLabel}
    </p>

    <h3 class="m-0">
      <a href={detailHref} class="border-b-0 hover:underline">{person.name}</a>
    </h3>

    <p class="text-ink-2 mt-2 m-0 text-sm">{person.role}</p>

    {person.bio_short && (
      <p class="mt-4 text-sm text-ink m-0" style="line-height: 1.5;">
        {person.bio_short}
      </p>
    )}

    {(notable || recent || notableTool || recentTool) && (
      <div class="mt-4 pt-4 border-t border-rule grid sm:grid-cols-2 gap-x-6 gap-y-4">
        {notable && notableMeta && (
          <div class="min-w-0">
            <p class="eyebrow m-0 mb-1">NOTABLE WORK</p>
            <p class="font-serif m-0" style="font-size: 16px; line-height: 1.3;">
              {notableMeta.url ? (
                <a href={notableMeta.url} class="border-b-0 hover:underline" data-external>{notable.title}</a>
              ) : (
                notable.title
              )}
            </p>
            <p class="font-mono text-xs text-ink-3 mt-1 m-0">
              <em class="not-italic">{notable.journal}</em>
              <span class="dot">·</span>
              {notable.year}
              {notableMeta.citations != null && (
                <>
                  <span class="dot">·</span>
                  {notableMeta.citations.toLocaleString()} citations
                </>
              )}
            </p>
          </div>
        )}
        {notableTool && (
          <div class="min-w-0">
            <p class="eyebrow m-0 mb-1">NOTABLE WORK</p>
            <p class="font-serif m-0" style="font-size: 16px; line-height: 1.3;">
              <a
                href={toolUrl(notableTool)}
                class="border-b-0 hover:underline"
                data-external={toolUrl(notableTool).startsWith('http') ? '' : null}
              >{notableTool.title}</a>
            </p>
            {toolMetaLine(notableTool) && (
              <p class="font-mono text-xs text-ink-3 mt-1 m-0">
                {toolMetaLine(notableTool)}
              </p>
            )}
          </div>
        )}
        {recent && recentMeta && (
          <div class="min-w-0">
            <p class="eyebrow m-0 mb-1">RECENT WORK</p>
            <p class="font-serif m-0" style="font-size: 16px; line-height: 1.3;">
              {recentMeta.url ? (
                <a href={recentMeta.url} class="border-b-0 hover:underline" data-external>{recent.title}</a>
              ) : (
                recent.title
              )}
            </p>
            <p class="font-mono text-xs text-ink-3 mt-1 m-0">
              <em class="not-italic">{recent.journal}</em>
              <span class="dot">·</span>
              {recent.year}
              {recentMeta.citations != null && (
                <>
                  <span class="dot">·</span>
                  {recentMeta.citations.toLocaleString()} citations
                </>
              )}
            </p>
          </div>
        )}
        {recentTool && (
          <div class="min-w-0">
            <p class="eyebrow m-0 mb-1">RECENT WORK</p>
            <p class="font-serif m-0" style="font-size: 16px; line-height: 1.3;">
              <a
                href={toolUrl(recentTool)}
                class="border-b-0 hover:underline"
                data-external={toolUrl(recentTool).startsWith('http') ? '' : null}
              >{recentTool.title}</a>
            </p>
            {toolMetaLine(recentTool) && (
              <p class="font-mono text-xs text-ink-3 mt-1 m-0">
                {toolMetaLine(recentTool)}
              </p>
            )}
          </div>
        )}
      </div>
    )}

    <div class="flex flex-wrap gap-x-5 gap-y-1 mt-4 text-xs font-mono uppercase tracking-wider">
      <a href={detailHref} class="text-ink-2 hover:text-ink border-b-0">Profile →</a>
      {person.cv_url && (
        <a href={person.cv_url} class="text-ink-2 hover:text-ink border-b-0" data-external>CV</a>
      )}
      {person.email && (
        <a href={`mailto:${person.email}`} class="text-ink-2 hover:text-ink border-b-0">Email</a>
      )}
      {person.personal_url && (
        <a href={person.personal_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Website</a>
      )}
      {person.scholar_url && (
        <a href={person.scholar_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Scholar</a>
      )}
      {orcidUrl && (
        <a href={orcidUrl} class="text-ink-2 hover:text-ink border-b-0" data-external>ORCID</a>
      )}
      {person.linkedin_url && (
        <a href={person.linkedin_url} class="text-ink-2 hover:text-ink border-b-0" data-external>LinkedIn</a>
      )}
      {person.github_url && (
        <a href={person.github_url} class="text-ink-2 hover:text-ink border-b-0" data-external>GitHub</a>
      )}
    </div>
  </div>

  <a href={detailHref} class="bare block shrink-0" style="line-height: 0;">
    {person.photo_filename ? (
      <img
        src={`/people/${person.photo_filename}`}
        alt={person.name}
        loading="lazy"
        class="w-full object-cover border border-rule"
        style="aspect-ratio: 1 / 1; border-radius: var(--radius-md);"
      />
    ) : (
      <div
        aria-hidden="true"
        class="flex items-center justify-center font-mono text-paper select-none"
        style={`width: 100%; aspect-ratio: 1/1; background: ${avatarBg}; border-radius: var(--radius-md); font-size: 64px;`}
      >
        {initials || '·'}
      </div>
    )}
  </a>
</article>
