---
import type { Person } from '../lib/types';

interface Props {
  person: Person;
}

const { person } = Astro.props;

// Stable spectral hue per slug so the avatar palette feels intentional.
const spectralColors = [
  'var(--spectral-2)',
  'var(--spectral-3)',
  'var(--spectral-4)',
  'var(--spectral-9)',
  'var(--spectral-10)',
  'var(--spectral-11)',
];
const hash = [...person.slug].reduce((a, c) => a + c.charCodeAt(0), 0);
const avatarBg = spectralColors[hash % spectralColors.length];

const initials = person.name
  .split(/\s+/)
  .filter((s) => /^[A-Z]/.test(s) && s.length > 1) // skip middle initials like "J."
  .slice(0, 2)
  .map((s) => s[0])
  .join('');

const detailHref = `/people/${person.slug}`;
const isAlum = person.status === 'alumni';

// Sheet cell format: "Institution" or "Institution, Role" — split on first comma.
const cp = person.current_position ?? '';
const commaIdx = cp.indexOf(',');
const nowInstitution = commaIdx === -1 ? cp.trim() : cp.slice(0, commaIdx).trim();
const nowRole = commaIdx === -1 ? '' : cp.slice(commaIdx + 1).trim();
---

<a
  href={detailHref}
  class="group block bg-paper border border-rule p-5 hover:border-rule-strong transition-colors border-b-0"
  style="min-height: 176px;"
>
  <div class="flex items-center gap-4 h-full">
    {
      person.photo_filename ? (
        <img
          src={`/people/${person.photo_filename}`}
          alt={person.name}
          width="88"
          height="88"
          loading="lazy"
          class="shrink-0 object-cover border border-rule"
          style="width: 88px; height: 88px; border-radius: var(--radius-md);"
        />
      ) : (
        <div
          aria-hidden="true"
          class="shrink-0 flex items-center justify-center font-mono text-2xl text-paper select-none"
          style={`width: 88px; height: 88px; background: ${avatarBg}; border-radius: var(--radius-md);`}
        >
          {initials || '·'}
        </div>
      )
    }
    <div class="min-w-0 flex-1 overflow-hidden">
      <p class="font-serif text-lg leading-tight m-0 line-clamp-2">{person.name}</p>
      <p class="text-ink-3 text-sm leading-tight mt-1 line-clamp-2">{person.role}</p>
      {
        isAlum && nowInstitution && (
          <p class="text-ink-3 text-xs mt-2 font-mono uppercase tracking-wider truncate" style="line-height: 1;">
            Now: {nowInstitution}{nowRole ? ',' : ''}
          </p>
        )
      }
      {
        isAlum && nowRole && (
          <p class="text-ink-3 text-xs font-mono uppercase tracking-wider truncate" style="line-height: 1; margin-top: 1px;">
            {nowRole}
          </p>
        )
      }
    </div>
  </div>
</a>
