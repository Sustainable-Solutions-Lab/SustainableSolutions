---
import type { Publication, Person } from '../lib/types';
import people from '../data/people.json';
import scholarDetails from '../../templates/scholar-details.json';
import { buildAuthorReplacements, splitAuthors } from '../lib/author-links';
import CitationChart from './CitationChart.astro';

interface Props {
  pub: Publication;
}

const { pub } = Astro.props;

// Build a {DOI → citations[]} lookup once at module load time. Survives
// the build because scholar-details.json is statically imported.
const citationsByDoi = new Map<string, Array<{ year: number; count: number }>>();
const totalsByDoi = new Map<string, number>();
for (const detail of Object.values(scholarDetails as Record<string, any>)) {
  if (detail?.doi && Array.isArray(detail.citations) && detail.citations.length > 0) {
    citationsByDoi.set(detail.doi, detail.citations);
    if (typeof detail.total_citations === 'number') {
      totalsByDoi.set(detail.doi, detail.total_citations);
    }
  }
}

const citationsForPub = pub.doi ? citationsByDoi.get(pub.doi) ?? null : null;
const totalCitationsForPub = pub.doi ? totalsByDoi.get(pub.doi) ?? null : null;

const doiUrl = pub.url ?? (pub.doi ? `https://doi.org/${pub.doi}` : null);

// Build a token → slug map from the publication's lab_authors slugs.
const replacements = buildAuthorReplacements(pub.lab_authors ?? [], people as Person[]);
const authorSegments = splitAuthors(pub.authors ?? '', replacements);

// Search blob — concatenated lowercase string the client-side filter greps.
const searchBlob = [pub.authors, pub.title, pub.journal, String(pub.year)]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();

// Citation tail: "9(3), 201–210"
const citationParts: string[] = [];
if (pub.volume_issue) citationParts.push(pub.volume_issue);
if (pub.pages) citationParts.push(pub.pages.replace(/-/g, '–'));
const citationTail = citationParts.join(', ');

// Featured cards get a hero block. If image_filename is set, use it.
// Otherwise: typographic placeholder with a stable Spectral-color stripe.
const isFeatured = !!pub.featured;
const heroImageUrl = pub.image_filename ? `/publications/${pub.image_filename}` : null;

const spectralColors = [
  'var(--spectral-2)',
  'var(--spectral-3)',
  'var(--spectral-4)',
  'var(--spectral-9)',
  'var(--spectral-10)',
  'var(--spectral-11)',
];
const heroHash = [...(pub.doi || pub.title || '')].reduce(
  (a, c) => a + c.charCodeAt(0),
  0,
);
const heroAccent = spectralColors[heroHash % spectralColors.length];
---

<li
  class:list={['relative', isFeatured ? 'py-6' : 'py-6 border-b border-rule']}
  data-pub
  data-year={pub.year}
  data-themes={(pub.themes ?? []).join(',')}
  data-lab-authors={(pub.lab_authors ?? []).join(',')}
  data-featured={String(pub.featured)}
  data-search={searchBlob}
>
  {isFeatured ? (
    <article
      class="grid md:grid-cols-[1fr_280px] gap-6 p-6 border border-rule bg-paper"
      style="border-radius: var(--radius-md);"
    >
      <div class="min-w-0">
        <p class="eyebrow m-0 mb-2">
          <span class="cardinal">FEATURED</span>
          <span class="dot">·</span>
          <em class="not-italic">{pub.journal}</em>
          <span class="dot">·</span>
          {pub.year}
        </p>

        <h3 class="m-0">
          {doiUrl ? (
            <a href={doiUrl} class="border-b-0 hover:underline" data-external>
              {pub.title}
            </a>
          ) : (
            pub.title
          )}
        </h3>

        <p class="text-ink-2 mt-2 text-sm m-0">
          {authorSegments.map((seg, i) => (
            <>
              {i > 0 && '; '}
              {seg.slug ? (
                <a href={`/people/${seg.slug}`} class="font-semibold text-ink border-b-0 hover:opacity-70">
                  {seg.text}
                </a>
              ) : (
                seg.text
              )}
            </>
          ))}
        </p>

        {pub.abstract && (
          <p class="mt-4 text-sm text-ink m-0" style="line-height: 1.5;">
            {pub.abstract}
          </p>
        )}

        {citationTail && (
          <p class="font-mono text-xs text-ink-3 mt-3 m-0">{citationTail}</p>
        )}

        <div class="flex flex-wrap gap-x-5 gap-y-1 mt-4 text-xs font-mono uppercase tracking-wider">
          {doiUrl && (<a href={doiUrl} class="text-ink-2 hover:text-ink border-b-0" data-external>DOI</a>)}
          {pub.pdf_url && (<a href={pub.pdf_url} class="text-ink-2 hover:text-ink border-b-0" data-external>PDF</a>)}
          {pub.code_url && (<a href={pub.code_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Code</a>)}
          {pub.brief_url && (<a href={pub.brief_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Brief</a>)}
          {pub.ppt_url && (<a href={pub.ppt_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Slides</a>)}
          {pub.press_url && (<a href={pub.press_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Press</a>)}
        </div>

        {pub.doi && (
          <div class="flex items-start gap-2 mt-4">
            {/* CSS `zoom` actually shrinks layout box + visual rendering, and
                applies to whatever the embed script injects (unlike transform,
                which the embed scripts can clobber). Native sizes:
                  Altmetric medium-donut ~64px → zoom 25/64 = 0.391
                  Dimensions small_circle ~32px → zoom 25/32 = 0.781   */}
            <div style="zoom: 0.390625;">
              <div
                class="altmetric-embed"
                data-badge-popover="right"
                data-badge-type="medium-donut"
                data-doi={pub.doi}
              ></div>
            </div>
            <div style="zoom: 0.78125;">
              <div
                class="__dimensions_badge_embed__"
                data-doi={pub.doi}
                data-style="small_circle"
              ></div>
            </div>
          </div>
        )}

        {citationsForPub && (
          <div class="mt-3">
            <CitationChart citations={citationsForPub} total={totalCitationsForPub} />
          </div>
        )}
      </div>

      {heroImageUrl ? (
        <img
          src={heroImageUrl}
          alt={pub.title}
          loading="lazy"
          class="w-full object-cover border border-rule"
          style="aspect-ratio: 16/10; border-radius: var(--radius-md);"
        />
      ) : (
        <div
          aria-hidden="true"
          class="relative flex flex-col justify-end p-4 overflow-hidden"
          style={`
            aspect-ratio: 16/10;
            background: var(--paper-2);
            border: 1px solid var(--rule);
            border-left: 4px solid ${heroAccent};
            border-radius: var(--radius-md);
          `}
        >
          <p class="font-serif leading-tight m-0" style="font-size: 19px;">{pub.journal}</p>
          <p class="font-mono text-xs text-ink-3 mt-1 m-0">{pub.year}</p>
        </div>
      )}
    </article>
  ) : (
    <>
      <div class="flex items-baseline justify-between gap-4 mb-2">
        <p class="eyebrow m-0">
          <em class="not-italic">{pub.journal}</em>
          <span class="dot">·</span>
          {pub.year}
        </p>
      </div>

      <h3 class="m-0">
        {doiUrl ? (
          <a href={doiUrl} class="border-b-0 hover:underline" data-external>
            {pub.title}
          </a>
        ) : (
          pub.title
        )}
      </h3>

      <p class="text-ink-2 mt-2 text-sm m-0">
        {authorSegments.map((seg, i) => (
          <>
            {i > 0 && '; '}
            {seg.slug ? (
              <a href={`/people/${seg.slug}`} class="font-semibold text-ink border-b-0 hover:opacity-70">
                {seg.text}
              </a>
            ) : (
              seg.text
            )}
          </>
        ))}
      </p>

      {citationTail && (
        <p class="font-mono text-xs text-ink-3 mt-2 m-0">{citationTail}</p>
      )}

      <div class="flex flex-wrap gap-x-5 gap-y-1 mt-3 text-xs font-mono uppercase tracking-wider">
        {doiUrl && (<a href={doiUrl} class="text-ink-2 hover:text-ink border-b-0" data-external>DOI</a>)}
        {pub.pdf_url && (<a href={pub.pdf_url} class="text-ink-2 hover:text-ink border-b-0" data-external>PDF</a>)}
        {pub.code_url && (<a href={pub.code_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Code</a>)}
        {pub.brief_url && (<a href={pub.brief_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Brief</a>)}
        {pub.ppt_url && (<a href={pub.ppt_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Slides</a>)}
        {pub.press_url && (<a href={pub.press_url} class="text-ink-2 hover:text-ink border-b-0" data-external>Press</a>)}
      </div>
    </>
  )}
</li>
