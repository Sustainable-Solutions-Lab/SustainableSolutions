---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

const sorted = (tools as Tool[])
  .slice()
  .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

const pubsByDoi = new Map<string, Publication>();
for (const p of publications as Publication[]) {
  if (p.doi) pubsByDoi.set(p.doi.toLowerCase(), p);
}

function resolveImage(filename: string | null): string | null {
  if (!filename) return null;
  for (const folder of ['tools', 'images']) {
    if (existsSync(resolve('public', folder, filename))) return `/${folder}/${filename}`;
  }
  return null;
}

const cards = sorted.map((t) => {
  const companion = t.doi ? pubsByDoi.get(t.doi.trim().toLowerCase()) ?? null : null;
  return {
    ...t,
    imgUrl: resolveImage(t.image_filename),
    href: t.link ?? '#',
    isExternal: typeof t.link === 'string' && /^https?:\/\//.test(t.link),
    companion,
  };
});
---

<BaseLayout title="Tools">
  <section class="container-content pt-8 pb-8">
    <p class="eyebrow mb-4">TOOLS</p>
    <h1>Things we ship</h1>
    <p class="lede max-w-prose mt-4">
      Interactive maps, datasets, and code releases that accompany our research.
    </p>
  </section>

  <section class="container-content pb-24">
    <ul class="list-none p-0 m-0 grid md:grid-cols-2 gap-6">
      {cards.map((t) => (
        <li class="m-0 p-0">
          <a
            href={t.href}
            class="block bg-paper border border-rule hover:border-ink-3 transition-colors border-b-0"
            style="border-radius: var(--radius-md); overflow: hidden;"
            data-external={t.isExternal ? '' : null}
          >
            {t.imgUrl && (
              <img
                src={t.imgUrl}
                alt={t.title}
                loading="lazy"
                class="block w-full object-cover"
                style="aspect-ratio: 16/10;"
              />
            )}
            <div class="p-6">
              {t.eyebrow && <p class="eyebrow m-0 mb-2">{t.eyebrow}</p>}
              <h3 class="m-0">{t.title}</h3>
              {t.summary && (
                <p class="text-ink-2 text-sm mt-2 m-0">{t.summary}</p>
              )}
              {t.companion && (
                <p class="font-mono text-xs text-ink-3 mt-3 m-0 uppercase tracking-wider">
                  Companion paper · <em class="not-italic">{t.companion.journal}</em> · {t.companion.year}
                </p>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

    {cards.length === 0 && (
      <p class="text-ink-3 text-sm">No tools yet — add a row to the Tools sheet.</p>
    )}
  </section>
</BaseLayout>
