---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'firemap' }, props: { title: 'Firemap' } },
  ];
}

const { title } = Astro.props;
---

<BaseLayout title={title} showCoordReadout={true}>
  <section class="container-content pt-16 pb-8">
    <p class="eyebrow mb-4">TOOL</p>
    <h1>{title}</h1>
    <p class="lede max-w-prose mt-4">
      Per-km² costs and benefits of wildfire fuel treatment in California.
    </p>
  </section>

  <section class="container-content pb-24">
    <div class="border border-rule aspect-[16/10] flex items-center justify-center text-ink-3 font-mono text-sm">
      Map island will mount here once Firemap components are ported into <code>src/tools/firemap/</code>.
    </div>
  </section>
</BaseLayout>
