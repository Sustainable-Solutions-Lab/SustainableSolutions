---
// Lab-scope heatmap — horizontal, system-colored rows.
//
// Figure-style block: small cardinal eyebrow → serif headline →
// italic subtitle → matrix → caption (matches the lab's editorial
// chart pattern from the design system reference).
//
// Rows    = human systems        (Energy · Food · Water · Materials · Climate · Health)
// Columns = response type, two sections separated by a small gap:
//             Mitigation:  General · Trade · Corp · C-mgmt
//             Impacts &
//             Adaptation:  General · Air · Heat · Drought · Fire · Flood
//
// Color: each row uses its system's Spectral hue. Cell saturation
// scales with paper count (zero count keeps the cell empty). Sub-
// category tags (system=energy:electricity, response=impacts:drought)
// roll up under the parent column / row by prefix match.

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const SYSTEMS = [
  { key: 'energy',    label: 'Energy',    color: 'var(--spectral-3)'  },
  { key: 'food',      label: 'Food',      color: 'var(--spectral-9)'  },
  { key: 'water',     label: 'Water',     color: 'var(--spectral-10)' },
  { key: 'materials', label: 'Materials', color: 'var(--spectral-11)' },
  { key: 'climate',   label: 'Climate',   color: 'var(--spectral-1)'  },
  { key: 'health',    label: 'Health',    color: 'var(--spectral-2)'  },
] as const;

const MIT_COLS = [
  { key: 'general',           label: 'General', match: 'mitigation' },
  { key: 'trade',             label: 'Trade',   match: 'mitigation:trade' },
  { key: 'corporate',         label: 'Corp',    match: 'mitigation:corporate' },
  { key: 'carbon-management', label: 'C-mgmt',  match: 'mitigation:carbon-management' },
] as const;

const IMP_COLS = [
  { key: 'general',       label: 'General', match: 'impacts' },
  { key: 'air-pollution', label: 'Air',     match: 'impacts:air-pollution' },
  { key: 'heat',          label: 'Heat',    match: 'impacts:heat' },
  { key: 'drought',       label: 'Drought', match: 'impacts:drought' },
  { key: 'fire',          label: 'Fire',    match: 'impacts:fire' },
  { key: 'flooding',      label: 'Flood',   match: 'impacts:flooding' },
] as const;

const pubs = publications as Publication[];

function axisMatches(values: string[], target: string): boolean {
  for (const v of values) {
    if (v === target) return true;
    if (v.startsWith(target + ':')) return true;
  }
  return false;
}

const cellCount: Record<string, number> = {};
const rowMax: Record<string, number> = {};
for (const sys of SYSTEMS) {
  let m = 0;
  for (const col of [...MIT_COLS, ...IMP_COLS]) {
    let n = 0;
    for (const p of pubs) {
      const s = (p.system ?? []) as string[];
      const r = (p.response ?? []) as string[];
      if (axisMatches(s, sys.key) && axisMatches(r, col.match)) n++;
    }
    cellCount[`${sys.key}|${col.key}`] = n;
    if (n > m) m = n;
  }
  rowMax[sys.key] = m;
}

function cellBg(systemKey: string, base: string, count: number): string {
  const max = rowMax[systemKey] || 1;
  if (!count) return 'var(--paper-2)';
  const opacity = 0.20 + (count / max) * 0.78;
  return `color-mix(in oklab, ${base} ${(opacity * 100).toFixed(0)}%, var(--paper))`;
}
---

<figure class="scope-figure">
  <p class="scope-eyebrow">
    <span class="cardinal-dot"></span>FIGURE · LAB SCOPE
  </p>
  <h3 class="scope-headline">Where the lab works</h3>
  <p class="scope-subtitle">
    <em>Publications by human system × response</em>
  </p>

  <div class="scope-grid">
    {/* Section labels above the columns */}
    <div class="cell-blank"></div>
    <div class="section-label section-mit">MITIGATION</div>
    <div class="section-spacer"></div>
    <div class="section-label section-imp">IMPACTS &amp; ADAPTATION</div>

    {/* Data rows */}
    {SYSTEMS.flatMap((sys) => [
      <div class="row-label" style={`color: ${sys.color};`}>{sys.label}</div>,
      <div class="cells-strip cells-mit">
        {MIT_COLS.map((c) => {
          const count = cellCount[`${sys.key}|${c.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(sys.key, sys.color, count)};`}
              title={`${sys.label} × ${c.label}: ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </div>,
      <div class="section-spacer"></div>,
      <div class="cells-strip cells-imp">
        {IMP_COLS.map((c) => {
          const count = cellCount[`${sys.key}|${c.key}`] ?? 0;
          return (
            <div
              class="cell"
              style={`background-color: ${cellBg(sys.key, sys.color, count)};`}
              title={`${sys.label} × ${c.label}: ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        })}
      </div>,
    ])}

    {/* Column labels below the cells */}
    <div class="cell-blank"></div>
    <div class="col-labels cols-mit">
      {MIT_COLS.map((c) => <span>{c.label}</span>)}
    </div>
    <div class="section-spacer"></div>
    <div class="col-labels cols-imp">
      {IMP_COLS.map((c) => <span>{c.label}</span>)}
    </div>
  </div>

  <figcaption class="scope-caption">
    <em>Each row is a human system. Hue identifies the system;
    saturation scales with the number of papers tagged in that
    cell. Hover for counts. Empty cells aren't blanks — they're
    intersections we haven't worked on yet.</em>
  </figcaption>
</figure>

<style>
  .scope-figure {
    margin: 0;
    width: 100%;
  }
  .scope-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cardinal);
    margin: 0 0 6px;
  }
  .scope-headline {
    font-family: var(--font-serif);
    font-size: 23px;
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .scope-subtitle {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 16px;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: minmax(64px, max-content) 4fr 8px 6fr;
    gap: 4px 0;
    align-items: stretch;
  }

  /* Section header band above cells */
  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--rule);
    align-self: end;
  }
  .section-mit { color: var(--spectral-10); }
  .section-imp { color: var(--spectral-2); }

  /* Row label in the system color */
  .row-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: right;
    padding: 0 8px 0 0;
    align-self: center;
    font-weight: 600;
  }

  /* Cell strips */
  .cells-strip {
    display: grid;
    gap: 3px;
    height: 26px;
  }
  .cells-mit { grid-template-columns: repeat(4, 1fr); }
  .cells-imp { grid-template-columns: repeat(6, 1fr); }
  .cell {
    background: var(--paper-2);
    border-radius: 2px;
    transition: outline 0.12s ease;
    cursor: default;
  }
  .cell:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }

  .section-spacer { width: 8px; }

  /* Column labels under the cells */
  .col-labels {
    display: grid;
    gap: 3px;
    padding-top: 4px;
    border-top: 1px solid var(--rule);
  }
  .cols-mit { grid-template-columns: repeat(4, 1fr); }
  .cols-imp { grid-template-columns: repeat(6, 1fr); }
  .col-labels span {
    font-family: var(--font-mono);
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-3);
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .scope-caption {
    margin: 14px 0 0;
    font-family: var(--font-serif);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-3);
    max-width: 64ch;
  }
</style>
