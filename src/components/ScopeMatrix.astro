---
// Lab-scope heatmap, reference-style.
//
// Columns = systems       (Energy · Food · Water · Materials · Climate · Health)
// Rows    = response type, two sections separated by a section header:
//             MITIGATION:  General · Trade · Carbon mgmt
//             IMPACTS &
//             ADAPTATION:  General · Air pollution · Heat · Drought · Fire · Flooding
//
// Cell color is mapped from the paper count via the lab's full
// ColorBrewer Spectral palette: low counts at the cool/green end,
// high counts at the warm/red end, no-papers cells stay paper.
// Single global scale (max count anywhere) so absolute density reads
// across the whole figure.
//
// Sub-tag rollup: system=energy:electricity → Energy column, response=
// impacts:drought → Drought row, etc. (prefix match).

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const SYSTEMS = [
  { key: 'energy',    label: 'Energy'    },
  { key: 'food',      label: 'Food'      },
  { key: 'water',     label: 'Water'     },
  { key: 'materials', label: 'Materials' },
  { key: 'climate',   label: 'Climate'   },
  { key: 'health',    label: 'Health'    },
] as const;

const MIT_ROWS = [
  { key: 'general',           label: 'General',     match: 'mitigation' },
  { key: 'trade',             label: 'Trade',       match: 'mitigation:trade' },
  { key: 'carbon-management', label: 'Carbon mgmt', match: 'mitigation:carbon-management' },
] as const;

const IMP_ROWS = [
  { key: 'general',       label: 'General',       match: 'impacts' },
  { key: 'air-pollution', label: 'Air pollution', match: 'impacts:air-pollution' },
  { key: 'heat',          label: 'Heat',          match: 'impacts:heat' },
  { key: 'drought',       label: 'Drought',       match: 'impacts:drought' },
  { key: 'fire',          label: 'Fire',          match: 'impacts:fire' },
  { key: 'flooding',      label: 'Flooding',      match: 'impacts:flooding' },
] as const;

const pubs = publications as Publication[];

function axisMatches(values: string[], target: string): boolean {
  for (const v of values) {
    if (v === target) return true;
    if (v.startsWith(target + ':')) return true;
  }
  return false;
}

// Key on row.match (which is unique) rather than row.key — MIT and IMP
// both have a "general" sub-row, and keying on row.key collided so the
// IMP general count silently overwrote the MIT general count.
const cellCount: Record<string, number> = {};
let globalMax = 0;
for (const sys of SYSTEMS) {
  for (const row of [...MIT_ROWS, ...IMP_ROWS]) {
    let n = 0;
    for (const p of pubs) {
      const s = (p.system ?? []) as string[];
      const r = (p.response ?? []) as string[];
      if (axisMatches(s, sys.key) && axisMatches(r, row.match)) n++;
    }
    cellCount[`${sys.key}|${row.match}`] = n;
    if (n > globalMax) globalMax = n;
  }
}

// Spectral ramp across the FULL palette: low counts at Spectral-10
// (deep blue), high at Spectral-1 (wine). Empty cells stay paper-toned.
//
// Rank-based percentile scaling: the data is heavy-tailed (one cell at
// ~100, most under 25), so value-based scales (linear and log alike)
// pile most cells into one half of the palette. Sorting non-zero cells
// by count and assigning palette positions by rank gives even visual
// spread regardless of distribution skew, so 1–2-paper cells reliably
// land at the blue end and the top reaches wine.
const nonZeroCounts = Object.values(cellCount).filter((n) => n > 0).sort((a, b) => a - b);
const rankDenom = Math.max(1, nonZeroCounts.length - 1);
function cellBg(count: number): string {
  if (!count) return 'var(--paper-2)';
  const lower = nonZeroCounts.filter((n) => n < count).length;
  const equal = nonZeroCounts.filter((n) => n === count).length;
  const rank = (lower + (equal - 1) / 2) / rankDenom;
  const idx = Math.max(1, Math.min(10, Math.round(10 - rank * 9)));
  return `var(--spectral-${idx})`;
}
---

<figure class="scope-figure">
  <p class="scope-eyebrow">
    <span class="cardinal-dot"></span>FIGURE · LAB SCOPE
  </p>
  <h3 class="scope-headline">Where the lab works</h3>
  <p class="scope-subtitle">
    <em>Publications by system and topic</em>
  </p>

  <div class="scope-grid">
    {/* Header row: empty section col + empty row-label col + 6 system labels. */}
    <div></div>
    <div></div>
    {SYSTEMS.map((s) => (
      <div class="col-label">{s.label}</div>
    ))}

    {/*
      Section labels rotated 90° as a left spine instead of horizontal banners,
      so every data row sits on the same vertical rhythm. The label spans the
      height of its rows via grid-row: span N.
    */}
    <div class="section-label section-mit" style={`grid-row: span ${MIT_ROWS.length};`}>
      Mitigation
    </div>

    {MIT_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.match}`] ?? 0;
          return (
            <a
              class="cell"
              href={`/publications?system=${encodeURIComponent(s.key)}&response=${encodeURIComponent(row.match)}`}
              style={`background-color: ${cellBg(count)};`}
              title={`${s.label} × Mitigation: ${row.label} · ${count} paper${count === 1 ? '' : 's'} · click to filter`}
              aria-label={`${s.label} × Mitigation: ${row.label} — ${count} papers`}
            ></a>
          );
        })}
      </>
    ))}

    <div class="section-label section-imp" style={`grid-row: span ${IMP_ROWS.length};`}>
      Impacts &amp;<br />adaptation
    </div>

    {IMP_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const count = cellCount[`${s.key}|${row.match}`] ?? 0;
          return (
            <a
              class="cell"
              href={`/publications?system=${encodeURIComponent(s.key)}&response=${encodeURIComponent(row.match)}`}
              style={`background-color: ${cellBg(count)};`}
              title={`${s.label} × Impacts: ${row.label} · ${count} paper${count === 1 ? '' : 's'} · click to filter`}
              aria-label={`${s.label} × Impacts: ${row.label} — ${count} papers`}
            ></a>
          );
        })}
      </>
    ))}

    {/* Colorbar lives inside the grid so it spans the system-cell
        columns only, not the spine + row-label gutter to its left. */}
    <div class="scope-colorbar">
      <span class="colorbar-end">Few</span>
      <div class="colorbar-gradient" aria-hidden="true"></div>
      <span class="colorbar-end colorbar-end-high">Many</span>
    </div>
  </div>
</figure>

<style>
  .scope-figure {
    margin: 0;
    width: 100%;
  }
  .scope-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cardinal);
    margin: 0 0 6px;
  }
  .scope-headline {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .scope-subtitle {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 14px;
  }

  .scope-grid {
    display: grid;
    grid-template-columns:
      28px                                /* spine: rotated section label (room for 2 lines) */
      minmax(80px, max-content)           /* row labels */
      repeat(6, minmax(46px, 1fr));       /* system cells */
    gap: 3px;
    align-items: stretch;
  }

  /* Column headers (sans-serif title case, no wrap, more reading-friendly
     than uppercase mono at this size). */
  .col-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-align: center;
    color: var(--ink-2);
    padding: 0 0 4px;
    white-space: nowrap;
    align-self: end;
  }

  /* Rotated spine label: bottom-to-top, vertically centered against its rows.
     Allows manual <br/> for multi-line labels (e.g. "Impacts & adaptation"). */
  .section-label {
    grid-column: 1;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
    text-align: center;
  }
  .section-mit { color: var(--spectral-10); }
  .section-imp { color: var(--spectral-2); }

  .row-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-2);
    text-align: right;
    padding-right: 8px;
    align-self: center;
    white-space: nowrap;
  }

  .cell {
    background: var(--paper-2);
    border-radius: 3px;
    height: 22px;
    border-bottom: 0;
    transition: outline 0.12s ease, transform 0.12s ease;
    cursor: pointer;
  }
  .cell:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }

  .scope-colorbar {
    grid-column: 3 / -1;                  /* under the cells, not under labels */
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
  }
  .colorbar-end {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    flex: none;
  }
  .colorbar-gradient {
    flex: 1;
    height: 8px;
    border-radius: 4px;
    background: linear-gradient(
      to right,
      var(--spectral-10) 0%,
      var(--spectral-9) 14%,
      var(--spectral-8) 28%,
      var(--spectral-7) 42%,
      var(--spectral-5) 56%,
      var(--spectral-4) 70%,
      var(--spectral-3) 84%,
      var(--spectral-2) 92%,
      var(--spectral-1) 100%
    );
  }
</style>
