---
// Compact lab-scope heatmap, two stacked 4×4 grids.
//
//   Top    — Mitigation (Spectral-10 blue base)
//   Bottom — Impacts & Adaptation (Spectral-2 red base)
//   Columns: Energy · Food · Water · Materials
//
// Reads two structured columns on the Publications sheet:
//   system    — { energy, food, water, materials } (multi-value)
//   response  — { mitigation, mitigation:trade, mitigation:corporate,
//                 mitigation:carbon-management, impacts,
//                 impacts:air-pollution, impacts:heat, impacts:flooding }
//
// A paper that's, say, system=energy,food + response=mitigation,impacts:heat
// contributes to four cells: (Energy × Mit/General), (Food × Mit/General),
// (Energy × Imp/Heat), (Food × Imp/Heat). Multi-tag papers spread across
// every matching cell — the matrix shows breadth, not a partition.

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';

const COLUMNS = [
  { key: 'energy',    label: 'Energy' },
  { key: 'food',      label: 'Food' },
  { key: 'water',     label: 'Water' },
  { key: 'materials', label: 'Materials' },
] as const;

type Section = {
  key: 'mitigation' | 'impacts';
  label: string;
  base: string;
  rows: { key: string; label: string; matchValue: string }[];
};

const SECTIONS: Section[] = [
  {
    key: 'mitigation',
    label: 'Mitigation',
    base: 'var(--spectral-10)',
    rows: [
      { key: 'general',           label: 'General',           matchValue: 'mitigation' },
      { key: 'trade',             label: 'Trade',             matchValue: 'mitigation:trade' },
      { key: 'corporate',         label: 'Corporate',         matchValue: 'mitigation:corporate' },
      { key: 'carbon-management', label: 'Carbon mgmt',       matchValue: 'mitigation:carbon-management' },
    ],
  },
  {
    key: 'impacts',
    label: 'Impacts & Adaptation',
    base: 'var(--spectral-2)',
    rows: [
      { key: 'general',       label: 'General',       matchValue: 'impacts' },
      { key: 'air-pollution', label: 'Air pollution', matchValue: 'impacts:air-pollution' },
      { key: 'heat',          label: 'Heat',          matchValue: 'impacts:heat' },
      { key: 'flooding',      label: 'Flooding',      matchValue: 'impacts:flooding' },
    ],
  },
];

const pubs = publications as Publication[];

const cellCount: Record<string, number> = {};
const sectionMax: Record<string, number> = {};
for (const sec of SECTIONS) {
  let secMax = 0;
  for (const col of COLUMNS) {
    for (const row of sec.rows) {
      let n = 0;
      for (const p of pubs) {
        const sys = (p.system ?? []) as string[];
        const resp = (p.response ?? []) as string[];
        if (sys.includes(col.key) && resp.includes(row.matchValue)) n++;
      }
      cellCount[`${sec.key}|${row.key}|${col.key}`] = n;
      if (n > secMax) secMax = n;
    }
  }
  sectionMax[sec.key] = secMax;
}

function cellBg(secKey: string, base: string, count: number): string {
  const max = sectionMax[secKey] || 1;
  if (!count) return 'var(--paper)';
  const opacity = 0.15 + (count / max) * 0.78;
  return `color-mix(in oklab, ${base} ${(opacity * 100).toFixed(0)}%, var(--paper))`;
}
---

<div class="scope-matrix-mini" aria-label="Scope of lab publications">
  {SECTIONS.map((sec) => (
    <div class="scope-section" data-section={sec.key}>
      {sec.rows.flatMap((row) =>
        COLUMNS.map((col) => {
          const count = cellCount[`${sec.key}|${row.key}|${col.key}`] ?? 0;
          return (
            <div
              class="scope-cell-mini"
              style={`background-color: ${cellBg(sec.key, sec.base, count)};`}
              title={`${col.label} × ${sec.label}: ${row.label} · ${count} paper${count === 1 ? '' : 's'}`}
            ></div>
          );
        }),
      )}
    </div>
  ))}
</div>

<style>
  .scope-matrix-mini {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 124px;
    flex: none;
  }
  .scope-section {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    aspect-ratio: 1 / 1;
    gap: 2px;
    padding: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
  }
  .scope-cell-mini {
    background: var(--paper);
    transition: outline 0.12s ease;
  }
  .scope-cell-mini:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }
</style>
