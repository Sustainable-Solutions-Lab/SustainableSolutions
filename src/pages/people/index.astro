---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="People">
  <section class="container-content pt-16 pb-8">
    <p class="eyebrow mb-4">PEOPLE</p>
    <h1>Lab members</h1>
    <p class="lede max-w-prose mt-4">
      Current researchers, postdocs, and students — and the alumni now leading their
      own labs and groups.
    </p>
  </section>

  <section class="container-content pb-24">
    <p class="text-ink-3 text-sm">
      Roster grid will populate from <code>src/data/people.json</code> (built from the
      <code>People</code> sheet tab). Filters: Current / Alumni / CIU.
    </p>
  </section>
</BaseLayout>
