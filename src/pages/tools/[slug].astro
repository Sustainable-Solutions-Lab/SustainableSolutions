---
// Auto-detail page for any tool whose row lives in the Tools sheet and that
// does NOT have its own hand-written .astro file (those win via Astro's
// static-route precedence and are listed in customPages below).

import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

export async function getStaticPaths() {
  // Slugs to skip:
  //   - 'firefuels'   has its own hand-written /tools/firefuels.astro
  //   - 'cornerstone' is a multi-link initiative; the index card already
  //     surfaces website / Zenodo / GitHub, no dedicated detail page.
  const skip = new Set(['firefuels', 'cornerstone']);
  const tools = (await import('../../data/tools.json')).default as Tool[];
  return tools
    .filter((t) => t.slug && !skip.has(t.slug))
    .map((t) => ({ params: { slug: t.slug }, props: { tool: t } }));
}

const { tool } = Astro.props;
const companion = tool.doi
  ? (publications as Publication[]).find((p) => p.doi?.toLowerCase() === tool.doi!.toLowerCase()) ?? null
  : null;
const companionUrl = companion?.url ?? (companion?.doi ? `https://doi.org/${companion.doi}` : null);

function resolveImage(filename: string | null): string | null {
  if (!filename) return null;
  for (const folder of ['tools', 'images']) {
    if (existsSync(resolve('public', folder, filename))) return `/${folder}/${filename}`;
  }
  return null;
}
const imgUrl = resolveImage(tool.image_filename);
---

<BaseLayout title={tool.title} description={tool.summary}>
  <article class="container-content pt-8 pb-8">
    {tool.eyebrow && <p class="eyebrow mb-4">{tool.eyebrow}</p>}
    <h1 class="m-0">{tool.title}</h1>
    {tool.summary && <p class="lede max-w-prose mt-4">{tool.summary}</p>}
    {companion && (
      <p class="font-mono text-xs text-ink-3 mt-3 m-0 uppercase tracking-wider">
        Companion paper ·
        {companionUrl ? (
          <a href={companionUrl} class="text-ink-2 hover:text-ink border-b-0" data-external>
            <em class="not-italic">{companion.journal}</em> · {companion.year}
          </a>
        ) : (
          <span><em class="not-italic">{companion.journal}</em> · {companion.year}</span>
        )}
      </p>
    )}
  </article>

  {imgUrl && (
    <section class="container-content pb-8">
      <img
        src={imgUrl}
        alt={tool.title}
        class="block w-full border border-rule"
        style="aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-md);"
      />
    </section>
  )}

  {tool.description && (
    <article class="container-prose pb-24">
      <p class="text-ink m-0" style="line-height: 1.6;">{tool.description}</p>
    </article>
  )}
</BaseLayout>
