---
const year = new Date().getFullYear();
---

<footer class="rule mt-10 border-t border-rule">
  <div class="container-content py-10 grid gap-8 md:grid-cols-3 text-sm">
    <div>
      <img
        class="lab-wordmark-img lab-wordmark-light"
        src="/logo-sdss-dark.png"
        alt="Sustainable Solutions Lab"
      />
      <img
        class="lab-wordmark-img lab-wordmark-dark"
        src="/logo-sdss-light.png"
        alt="Sustainable Solutions Lab"
      />
    </div>

    <div>
      <p class="eyebrow mb-2">Contact</p>
      <p class="text-ink-3 m-0">
        Steven J. Davis<br />
        Professor of Earth System Science<br />
        Stanford Doerr School of Sustainability
      </p>
      <p class="text-ink-2 mt-2 m-0">
        <a href="mailto:sjdavis@stanford.edu">sjdavis@stanford.edu</a>
      </p>
    </div>

    <div>
      <p class="eyebrow mb-2">Stanford</p>
      <p class="text-ink-2">
        <a href="https://sustainability.stanford.edu" data-external>Doerr School of Sustainability</a><br />
        <a href="https://earth.stanford.edu" data-external>Earth System Science</a>
      </p>
    </div>
  </div>

  <div class="border-t border-rule">
    <div class="container-content py-4 flex justify-between items-center text-xs text-ink-3 font-mono">
      <span>© {year} Stanford University</span>
      <span>v0.1</span>
    </div>
  </div>
</footer>

<style>
  .lab-wordmark-img {
    display: block;
    height: 44px;
    width: auto;
    max-width: 100%;
  }
  .lab-wordmark-dark { display: none; }
  :global([data-theme="dark"]) .lab-wordmark-light { display: none; }
  :global([data-theme="dark"]) .lab-wordmark-dark { display: block; }
</style>
