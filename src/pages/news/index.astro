---
import BaseLayout from '../../layouts/BaseLayout.astro';
import news from '../../data/news.json';
import publications from '../../data/publications.json';
import tools from '../../data/tools.json';
import type { NewsItem, Publication, Tool } from '../../lib/types';
import { SYSTEMS } from '../../lib/systems';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

// Resolve a news image_filename to a /public/-relative URL. Accepts either
// a bare filename (searched across common folders) or a path under /public/
// (e.g. "news/SSF.png"). Falls back to null if no match found.
function resolveNewsImage(filename: string | null | undefined): string | null {
  if (!filename) return null;
  if (filename.includes('/')) {
    if (existsSync(resolve('public', filename))) return `/${filename}`;
  }
  for (const folder of ['news', 'images/news', 'featured', 'images']) {
    if (existsSync(resolve('public', folder, filename))) return `/${folder}/${filename}`;
  }
  return null;
}

const TOOLS_WITHOUT_DETAIL_PAGE = new Set(['cornerstone']);
function toolHref(t: Tool): string {
  if (t.link) return t.link;
  if (TOOLS_WITHOUT_DETAIL_PAGE.has(t.slug)) return '/tools';
  return `/tools/${t.slug}`;
}

// Filter taxonomy mirrors the publications page so users get the same
// vocabulary across both lists.
const SYSTEM_OPTIONS = [
  { value: 'energy',    label: 'Energy'    },
  { value: 'food',      label: 'Food'      },
  { value: 'water',     label: 'Water'     },
  { value: 'materials', label: 'Materials' },
  { value: 'climate',   label: 'Climate'   },
  { value: 'health',    label: 'Health'    },
];
const TOPIC_GROUPS = [
  {
    label: 'Mitigation',
    options: [
      { value: 'mitigation',                   label: 'Mitigation (all)' },
      { value: 'mitigation:trade',             label: 'Trade' },
      { value: 'mitigation:carbon-management', label: 'Carbon management' },
    ],
  },
  {
    label: 'Impacts & adaptation',
    options: [
      { value: 'impacts',               label: 'Impacts (all)' },
      { value: 'impacts:air-pollution', label: 'Air pollution' },
      { value: 'impacts:heat',          label: 'Heat' },
      { value: 'impacts:drought',       label: 'Drought' },
      { value: 'impacts:fire',          label: 'Fire' },
      { value: 'impacts:flooding',      label: 'Flooding' },
    ],
  },
];
const TYPE_OPTIONS = ['paper', 'press', 'op-ed', 'talk', 'award', 'other'];

// Canonicalize a date cell to ISO "YYYY-MM-DD" for sorting + display.
// Accepts:  2024-03-15, 3/15/2024, 3/15/24, 03/15/2024  (and missing day forms)
function toIsoDate(d: string | null | undefined): string {
  if (!d) return '';
  const s = String(d).trim();
  let m = s.match(/^(\d{4})-(\d{1,2})(?:-(\d{1,2}))?$/);
  if (m) {
    const day = m[3] ?? '01';
    return `${m[1]}-${m[2].padStart(2, '0')}-${day.padStart(2, '0')}`;
  }
  m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
  if (m) {
    let yr = parseInt(m[3], 10);
    if (yr < 100) yr += yr >= 50 ? 1900 : 2000;
    return `${yr}-${m[1].padStart(2, '0')}-${m[2].padStart(2, '0')}`;
  }
  return s; // unrecognized — sort as-is
}

// Sort reverse-chronologically. Items with bad/missing dates sink last.
const items = (news as NewsItem[])
  .slice()
  .filter((n) => n.title)
  .map((n) => ({ ...n, date: toIsoDate(n.date) }))
  .sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));

const pubsByDoi = new Map<string, Publication>();
for (const p of publications as Publication[]) {
  if (p.doi) pubsByDoi.set(p.doi.toLowerCase(), p);
}

const toolsBySlug = new Map<string, Tool>();
for (const t of tools as Tool[]) toolsBySlug.set(t.slug, t);

const systemBySlug = new Map(SYSTEMS.map((s) => [s.slug, s]));

// Topic-axis text color for in-text chips. AA-passing variants live as
// CSS vars in colors_and_type.css.
function responseColor(r: string): string {
  if (r === 'mitigation') return 'var(--mitigation-text)';
  if (r === 'impacts') return 'var(--impacts-text)';
  return 'var(--ink-3)';
}
function topLevels(values: string[] | undefined): string[] {
  return Array.from(new Set((values ?? []).map((v) => v.split(':')[0])));
}

// Per-card derivations: companion paper (when doi set), effective system
// and topic (item's own values, else inherited from the companion paper),
// stripe color, and a search blob the client filter greps over.
const cards = items.map((n) => {
  const companion = n.doi ? pubsByDoi.get(n.doi.trim().toLowerCase()) ?? null : null;
  const companionTools = (n.tool ?? [])
    .map((slug) => toolsBySlug.get(slug))
    .filter((t): t is Tool => !!t);
  const sys = (n.system && n.system.length > 0)
    ? n.system
    : ((companion?.system ?? []) as string[]);
  const topic = (n.topic && n.topic.length > 0)
    ? n.topic
    : ((companion?.response ?? []) as string[]);
  const topSys = topLevels(sys);
  const topTopic = topLevels(topic);
  const primary = topSys[0] ? systemBySlug.get(topSys[0]) ?? null : null;
  const stripe = primary?.color ?? 'var(--ink-4)';
  const year = n.date ? n.date.slice(0, 4) : '';
  const toolsBlob = companionTools.map((t) => t.title).join(' ');
  const searchBlob = [n.title, n.summary, n.source, companion?.title, companion?.journal, toolsBlob]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  const imageUrl = resolveNewsImage(n.image_filename);
  return { n, companion, companionTools, sys, topic, topSys, topTopic, stripe, year, searchBlob, imageUrl };
});

// Years present in the data, descending. Drop empties.
const years = Array.from(new Set(cards.map((c) => c.year).filter(Boolean)))
  .sort((a, b) => b.localeCompare(a));

// ── Outlet donut: top-5 sources + "Other" rollup ─────────────────────────────
const outletCounts = new Map<string, number>();
for (const c of cards) {
  const src = (c.n.source ?? '').trim();
  if (!src) continue;
  outletCounts.set(src, (outletCounts.get(src) ?? 0) + 1);
}
const sortedOutlets = [...outletCounts.entries()].sort((a, b) => b[1] - a[1]);
const top5Outlets = sortedOutlets.slice(0, 5);
const otherOutletCount = sortedOutlets.slice(5).reduce((s, [, n]) => s + n, 0);
const donutSlices: Array<{ label: string; count: number; color: string }> = [];
const donutColors = [
  'var(--spectral-2)',  'var(--spectral-3)',  'var(--spectral-5)',
  'var(--spectral-9)',  'var(--spectral-10)', 'var(--spectral-11)',
];
top5Outlets.forEach(([label, count], i) => {
  donutSlices.push({ label, count, color: donutColors[i] });
});
if (otherOutletCount > 0) {
  donutSlices.push({ label: 'Other', count: otherOutletCount, color: 'var(--ink-4)' });
}
const donutTotal = donutSlices.reduce((s, x) => s + x.count, 0);
// Build cumulative dash offsets for the donut segments. Drawing on a
// circumference of 100 (viewBox-relative units) — segment length = share × 100.
const donutSegments = (() => {
  let offset = 0;
  return donutSlices.map((s) => {
    const len = donutTotal > 0 ? (s.count / donutTotal) * 100 : 0;
    const seg = { ...s, len, offset };
    offset += len;
    return seg;
  });
})();

// ── Stacked annual area: per-system coverage per year ──────────────────────
// Each card contributes once (under its first top-level system); cards with
// no system tag fall into an "Unspecified" band so the stack equals the total
// news count for each year.
const trendYears = (() => {
  const ys = cards.map((c) => parseInt(c.year, 10)).filter((n) => !isNaN(n));
  if (ys.length === 0) return [] as number[];
  const min = Math.min(...ys);
  const max = Math.max(...ys);
  const out: number[] = [];
  for (let y = min; y <= max; y++) out.push(y);
  return out;
})();

const UNSPECIFIED = '__unspecified';
function primarySys(c: typeof cards[number]): string {
  return c.topSys[0] ?? UNSPECIFIED;
}
const presentSlugs = new Set(cards.map(primarySys));
// Stack order: matrix order (Energy, Food, …) then Unspecified at top.
const stackOrder = [
  ...SYSTEMS.map((s) => s.slug).filter((slug) => presentSlugs.has(slug)),
  ...(presentSlugs.has(UNSPECIFIED) ? [UNSPECIFIED] : []),
];
const stackMeta: Record<string, { title: string; color: string }> = {};
for (const s of SYSTEMS) stackMeta[s.slug] = { title: s.title, color: s.color };
stackMeta[UNSPECIFIED] = { title: 'Unspecified', color: 'var(--ink-4)' };

const annualBySlug = new Map<string, number[]>();
for (const slug of stackOrder) {
  const arr: number[] = [];
  for (const y of trendYears) {
    const yStr = String(y);
    arr.push(cards.filter((c) => c.year === yStr && primarySys(c) === slug).length);
  }
  annualBySlug.set(slug, arr);
}

const trendMax = trendYears.length === 0
  ? 1
  : Math.max(1, ...trendYears.map((_, i) =>
      stackOrder.reduce((s, slug) => s + (annualBySlug.get(slug)![i] ?? 0), 0),
    ));

// SVG geometry: 320x140 with small padding for axis labels.
const TREND_W = 320;
const TREND_H = 140;
const TREND_PAD = { l: 6, r: 6, t: 6, b: 16 };
const innerW = TREND_W - TREND_PAD.l - TREND_PAD.r;
const innerH = TREND_H - TREND_PAD.t - TREND_PAD.b;

// Build each band's polygon (top path forward + baseline path reversed).
function bandPolygon(slug: string): string {
  const idx = stackOrder.indexOf(slug);
  if (idx < 0) return '';
  // Per-year top = sum of annual counts of all bands at or below this one;
  // bottom = same, excluding this band.
  const tops: number[] = trendYears.map((_, i) =>
    stackOrder.slice(0, idx + 1).reduce((s, sl) => s + (annualBySlug.get(sl)![i] ?? 0), 0),
  );
  const bottoms: number[] = trendYears.map((_, i) =>
    stackOrder.slice(0, idx).reduce((s, sl) => s + (annualBySlug.get(sl)![i] ?? 0), 0),
  );
  const xAt = (i: number) => trendYears.length === 1
    ? TREND_PAD.l + innerW / 2
    : TREND_PAD.l + (i / (trendYears.length - 1)) * innerW;
  const yScale = (v: number) => TREND_PAD.t + innerH - (v / trendMax) * innerH;

  const fwd = tops.map((v, i) => `${xAt(i).toFixed(1)},${yScale(v).toFixed(1)}`);
  const rev = bottoms.map((v, i) => `${xAt(i).toFixed(1)},${yScale(v).toFixed(1)}`).reverse();
  return [...fwd, ...rev].join(' ');
}

const trendBands = stackOrder.map((slug) => ({
  slug,
  title: stackMeta[slug].title,
  color: stackMeta[slug].color,
  points: bandPolygon(slug),
  // Total = sum of this band's annual counts across all years.
  total: (annualBySlug.get(slug) ?? []).reduce((s, v) => s + v, 0),
}));
const grandTotal = trendBands.reduce((s, b) => s + b.total, 0);

function sourceLabel(n: NewsItem): string {
  const s = n.source ?? '';
  return s ? s.toUpperCase() : (n.type ? String(n.type).toUpperCase() : 'NEWS');
}
function dateLabel(d: string): string {
  if (!d) return '';
  const m = d.match(/^(\d{4})-(\d{1,2})(?:-(\d{1,2}))?/);
  if (!m) return d;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const month = months[parseInt(m[2], 10) - 1] ?? m[2];
  const day = m[3] ? ` ${parseInt(m[3], 10)}` : '';
  return `${month}${day} ${m[1]}`;
}

const total = cards.length;
---

<BaseLayout title="News">
  <section class="container-content pt-8 pb-6">
    <div class="grid md:grid-cols-[2fr_3fr] gap-8 md:gap-10">
      <div class="min-w-0">
        <p class="eyebrow mb-4">NEWS</p>
        <h1>Press, papers, and milestones</h1>
        <p class="lede mt-4">
          Reverse-chronological. Press coverage of our work, paper releases,
          op-eds, talks, and lab milestones.
        </p>
      </div>

      {donutTotal > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <figure class="m-0">
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-cardinal m-0 mb-1">
              <span class="cardinal-dot"></span>FIGURE · TOP OUTLETS
            </p>
            <h2 class="font-serif font-semibold text-base m-0" style="line-height: 1.15;">Where it lands</h2>
            <p class="font-serif italic text-xs text-ink-3 mt-0 mb-3 m-0">
              Top 5 outlets across {donutTotal} items
            </p>
            <div class="flex items-center gap-3">
              <svg
                viewBox="-2 -2 40 40"
                role="img"
                aria-label="Distribution of media coverage by outlet"
                style="width: 88px; height: 88px; flex: none;"
              >
                {/* Stacked donut segments using stroke-dashoffset. r=15.915 → C=100. */}
                {donutSegments.map((s) => (
                  <circle
                    cx="18" cy="18" r="15.915"
                    fill="transparent"
                    stroke={s.color}
                    stroke-width="6"
                    stroke-dasharray={`${s.len.toFixed(3)} ${(100 - s.len).toFixed(3)}`}
                    stroke-dashoffset={(-s.offset).toFixed(3)}
                    transform="rotate(-90 18 18)"
                  ><title>{s.label}: {s.count} mention{s.count === 1 ? '' : 's'}</title></circle>
                ))}
              </svg>
              <ul class="list-none p-0 m-0 text-xs font-mono space-y-1 min-w-0">
                {donutSegments.map((s) => (
                  <li class="flex items-baseline gap-2 m-0 min-w-0">
                    <span class="inline-block shrink-0" style={`width: 8px; height: 8px; background: ${s.color}; border-radius: 1px;`}></span>
                    <span class="text-ink-2 truncate" title={s.label}>{s.label}</span>
                    <span class="text-ink-3 ml-auto">{s.count}</span>
                  </li>
                ))}
              </ul>
            </div>
          </figure>

          <figure class="m-0">
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-cardinal m-0 mb-1">
              <span class="cardinal-dot"></span>FIGURE · COVERAGE BY YEAR
            </p>
            <h2 class="font-serif font-semibold text-base m-0" style="line-height: 1.15;">Drumbeat over time</h2>
            <p class="font-serif italic text-xs text-ink-3 mt-0 mb-3 m-0">
              Annual coverage, stacked by system
            </p>
            <svg
              viewBox={`0 0 ${TREND_W} ${TREND_H}`}
              preserveAspectRatio="none"
              role="img"
              aria-label={`Annual news coverage ${trendYears[0]} to ${trendYears[trendYears.length - 1]} stacked by system`}
              class="block w-full"
              style={`height: 110px;`}
            >
              {trendBands.map((b) => (
                <polygon
                  points={b.points}
                  fill={b.color}
                  fill-opacity="0.85"
                  stroke="var(--paper)"
                  stroke-width="0.5"
                ><title>{b.title}: {b.total} items</title></polygon>
              ))}
            </svg>
            <div class="flex justify-between font-mono text-[10px] text-ink-3 mt-0">
              <span>{trendYears[0]}</span>
              <span>{trendYears[trendYears.length - 1]} · {grandTotal} total</span>
            </div>
            <ul class="list-none p-0 m-0 mt-2 flex flex-wrap gap-x-3 gap-y-1 text-[10px] font-mono">
              {trendBands.slice().reverse().map((b) => (
                <li class="flex items-center gap-1 m-0">
                  <span class="inline-block" style={`width: 10px; height: 10px; background: ${b.color}; border-radius: 1px;`}></span>
                  <span class="text-ink-2">{b.title}</span>
                  <span class="text-ink-3">{b.total}</span>
                </li>
              ))}
            </ul>
          </figure>
        </div>
      )}
    </div>
  </section>

  <section class="container-content pb-24">
    <div
      class="flex flex-wrap items-center gap-2 md:gap-4 py-2 md:py-4 mb-2 border-y border-rule bg-paper sticky z-20"
      style="top: 56px;"
      role="search"
    >
      <label class="flex items-center gap-2 text-sm flex-1 md:flex-initial min-w-0">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Search</span>
        <input
          id="news-search"
          type="search"
          placeholder="Search…"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink w-full md:w-auto"
          style="border-radius: var(--radius-sm); min-width: 0;"
        />
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Year</span>
        <select
          id="news-year"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All years</option>
          {years.map((y) => <option value={y}>{y}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Type</span>
        <select
          id="news-type"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All types</option>
          {TYPE_OPTIONS.map((t) => <option value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">System</span>
        <select
          id="news-system"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All systems</option>
          {SYSTEM_OPTIONS.map((s) => <option value={s.value}>{s.label}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3 hidden md:inline">Topic</span>
        <select
          id="news-topic"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All topics</option>
          {TOPIC_GROUPS.map((g) => (
            <optgroup label={g.label}>
              {g.options.map((o) => <option value={o.value}>{o.label}</option>)}
            </optgroup>
          ))}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <input id="news-featured" type="checkbox" class="accent-cardinal" />
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Featured</span>
      </label>

      <span id="news-count" class="ml-auto font-mono text-xs uppercase tracking-wider text-ink-3">
        {total} of {total}
      </span>
    </div>

    {total === 0 ? (
      <p class="text-ink-3 text-sm">No news items yet — add rows to the News tab in the sheet.</p>
    ) : (
      <>
      <h2 class="sr-only">News items</h2>
      <ul id="news-list" class="list-none p-0 m-0">
        {cards.map(({ n, companion, companionTools, sys, topic, topSys, topTopic, stripe, year, searchBlob, imageUrl }) => {
          const isExternal = !!n.link && /^https?:\/\//.test(n.link);
          const companionUrl = companion
            ? (companion.url ?? (companion.doi ? `https://doi.org/${companion.doi}` : null))
            : null;
          return (
            <li
              class="m-0 p-0 py-5 border-b border-rule"
              data-news
              data-year={year}
              data-type={n.type ?? ''}
              data-system={sys.join(',')}
              data-topic={topic.join(',')}
              data-tool={(n.tool ?? []).join(',')}
              data-people={(n.people ?? []).join(',')}
              data-featured={String(!!n.featured)}
              data-search={searchBlob}
            >
              <article
                class:list={[
                  'pl-4',
                  imageUrl ? 'grid md:grid-cols-[1fr_240px] gap-6' : '',
                ]}
                style={`border-left: 4px solid ${stripe};`}
              >
                <div class="min-w-0">
                <p class="eyebrow m-0 mb-1">
                  <span class="text-ink-2">{sourceLabel(n)}</span>
                  <span class="dot">·</span>
                  <span class="text-ink-3">{dateLabel(n.date)}</span>
                  {n.type && n.type !== 'press' && n.source && String(n.type).toUpperCase() !== sourceLabel(n) && (
                    <>
                      <span class="dot">·</span>
                      <span style={`color: ${n.type === 'op-ed' ? 'var(--cardinal)' : 'var(--ink-3)'};`}>{String(n.type).toUpperCase()}</span>
                    </>
                  )}
                  {topSys.map((s) => {
                    const meta = systemBySlug.get(s);
                    if (!meta) return null;
                    return (
                      <>
                        <span class="dot">·</span>
                        <span style={`color: ${meta.textColor};`}>{meta.title.toUpperCase()}</span>
                      </>
                    );
                  })}
                  {topTopic.map((t) => (
                    <>
                      <span class="dot">·</span>
                      <span style={`color: ${responseColor(t)};`}>{t.toUpperCase()}</span>
                    </>
                  ))}
                </p>

                <h3 class="m-0" style="font-size: 19px; line-height: 1.3;">
                  {n.link ? (
                    <a
                      href={n.link}
                      class="border-b-0 hover:underline"
                      data-external={isExternal ? '' : null}
                    >{n.title}</a>
                  ) : (
                    n.title
                  )}
                </h3>

                {n.summary && (
                  <p class="text-ink-2 text-sm mt-2 m-0" style="line-height: 1.5;">
                    {n.summary}
                  </p>
                )}

                {companion && (
                  <p class="font-mono text-xs text-ink-3 mt-2 m-0">
                    Companion paper:
                    {companionUrl ? (
                      <a href={companionUrl} class="text-ink-2 hover:text-ink border-b-0 ml-1" data-external>
                        <em class="not-italic">{companion.title}</em>
                      </a>
                    ) : (
                      <em class="not-italic ml-1">{companion.title}</em>
                    )}
                    <span class="dot">·</span>
                    {companion.journal} · {companion.year}
                  </p>
                )}

                {companionTools.length > 0 && (
                  <p class="font-mono text-xs text-ink-3 mt-1 m-0">
                    Companion tool:
                    {companionTools.map((t, i) => (
                      <>
                        {i > 0 && <span class="dot">·</span>}
                        <a href={toolHref(t)} class="text-ink-2 hover:text-ink border-b-0 ml-1">
                          {t.title}
                        </a>
                      </>
                    ))}
                  </p>
                )}
                </div>
                {imageUrl && (
                  <a
                    href={n.link ?? undefined}
                    class="block shrink-0 self-start border-b-0"
                    target={isExternal ? '_blank' : undefined}
                    rel={isExternal ? 'noopener' : undefined}
                  >
                    <img
                      src={imageUrl}
                      alt={n.title}
                      loading="lazy"
                      class="block w-full object-cover border border-rule"
                      style="aspect-ratio: 16/10; border-radius: var(--radius-md);"
                    />
                  </a>
                )}
              </article>
            </li>
          );
        })}
      </ul>
      </>
    )}

    <p id="news-empty" hidden class="py-12 text-center text-ink-3 text-sm">
      No news items match the current filters.
    </p>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const search = document.getElementById('news-search');
    const yearSel = document.getElementById('news-year');
    const typeSel = document.getElementById('news-type');
    const systemSel = document.getElementById('news-system');
    const topicSel = document.getElementById('news-topic');
    const feat = document.getElementById('news-featured');
    const list = document.getElementById('news-list');
    const empty = document.getElementById('news-empty');
    const count = document.getElementById('news-count');
    if (!list || !count) return;

    const items = Array.from(list.querySelectorAll('[data-news]'));
    const total = items.length;

    function axisHasPrefix(values, target) {
      if (!target) return true;
      for (const v of values) {
        if (!v) continue;
        if (v === target) return true;
        if (v.startsWith(target + ':')) return true;
      }
      return false;
    }

    const apply = () => {
      const q = (search?.value ?? '').trim().toLowerCase();
      const y = yearSel?.value ?? '';
      const t = typeSel?.value ?? '';
      const sys = systemSel?.value ?? '';
      const top = topicSel?.value ?? '';
      const f = feat?.checked ?? false;

      let visible = 0;
      for (const li of items) {
        const sysVals = (li.dataset.system ?? '').split(',').filter(Boolean);
        const topicVals = (li.dataset.topic ?? '').split(',').filter(Boolean);
        const ok =
          (!q || (li.dataset.search ?? '').includes(q)) &&
          (!y || li.dataset.year === y) &&
          (!t || li.dataset.type === t) &&
          axisHasPrefix(sysVals, sys) &&
          axisHasPrefix(topicVals, top) &&
          (!f || li.dataset.featured === 'true');
        li.hidden = !ok;
        if (ok) visible++;
      }

      count.textContent = `${visible} of ${total}`;
      if (empty) empty.hidden = visible !== 0;
    };

    // Pre-fill filters from URL params: ?system=energy, ?topic=mitigation, ?type=press, ?year=2023
    const params = new URLSearchParams(window.location.search);
    const setIf = (sel, value) => {
      if (!sel || !value) return;
      const opt = Array.from(sel.options).find((o) => o.value === value);
      if (opt) sel.value = value;
    };
    setIf(yearSel,   params.get('year'));
    setIf(typeSel,   params.get('type'));
    setIf(systemSel, (params.get('system') ?? '').trim());
    setIf(topicSel,  (params.get('topic') ?? params.get('response') ?? '').trim());

    [search, yearSel, typeSel, systemSel, topicSel, feat].forEach((el) => {
      el?.addEventListener('input', apply);
      el?.addEventListener('change', apply);
    });

    apply();
  })();
</script>
