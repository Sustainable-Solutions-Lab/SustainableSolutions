---
import BaseLayout from '../../layouts/BaseLayout.astro';
import publications from '../../data/publications.json';
import type { Publication } from '../../lib/types';
import { SYSTEMS, systemMatches } from '../../lib/systems';
import { totalCitations } from '../../lib/citations';

const pubs = publications as Publication[];
const cards = SYSTEMS.map((s) => {
  const myPubs = pubs.filter((p) => systemMatches(p.system, s.slug));
  const cites = myPubs.reduce((sum, p) => sum + totalCitations(p), 0);
  return { ...s, count: myPubs.length, cites };
});
---

<BaseLayout title="Research" showCoordReadout={true}>
  <section class="container-content pt-8 pb-6">
    <p class="eyebrow mb-4">RESEARCH</p>
    <h1>What we study</h1>
    <p class="lede max-w-prose mt-4">
      The lab studies the unavoidable environmental tradeoffs of energy, food,
      and material security — and the most viable paths to a sustainable future.
      Our work spans six interconnected systems.
    </p>
  </section>

  <section class="container-content pb-24">
    <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0">
      {cards.map((s) => (
        <li class="m-0 p-0 h-full">
          <a
            href={`/research/${s.slug}`}
            class="flex flex-col h-full bg-paper border border-rule hover:border-ink-3 transition-colors border-b-0"
            style={`border-radius: var(--radius-md); border-top: 4px solid ${s.color}; overflow: hidden;`}
          >
            <div class="p-5 flex-1 flex flex-col">
              <p class="eyebrow m-0 mb-2" style={`color: ${s.color};`}>SYSTEM</p>
              <h3 class="m-0">{s.title}</h3>
              <p class="text-ink-2 text-sm mt-2 m-0" style="line-height: 1.5;">
                {s.summary}
              </p>
              <p class="font-mono text-xs uppercase tracking-wider text-ink-3 mt-auto pt-4 m-0">
                <span class="text-ink-2">{s.count}</span> paper{s.count === 1 ? '' : 's'}
                <span class="dot">·</span>
                <span class="text-ink-2">{s.cites.toLocaleString()}</span> cite{s.cites === 1 ? '' : 's'}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
