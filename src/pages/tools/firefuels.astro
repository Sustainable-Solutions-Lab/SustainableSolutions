---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Firefuels from '../../tools/firefuels/Firefuels.jsx';
import tools from '../../data/tools.json';
import publications from '../../data/publications.json';
import type { Tool, Publication } from '../../lib/types';

const tool = (tools as Tool[]).find((t) => t.slug === 'firefuels') ?? null;
const companionPub = tool?.doi
  ? (publications as Publication[]).find((p) => p.doi?.toLowerCase() === tool.doi!.toLowerCase()) ?? null
  : null;
const companion = companionPub
  ? {
      title: companionPub.title,
      journal: companionPub.journal,
      year: companionPub.year,
      url: companionPub.url ?? (companionPub.doi ? `https://doi.org/${companionPub.doi}` : null),
    }
  : null;
---

<BaseLayout
  title={tool?.title ?? 'Firefuels'}
  description={tool?.summary}
  hideFooter={true}
>
  <section aria-label="Interactive map">
    <div
      class="firefuels-frame"
      style="width: 100%; overflow: hidden; background: var(--paper-2);"
    >
      <Firefuels client:only="react" companion={companion} />
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Map fills the viewport from below the sticky nav (56 px) to the bottom
     edge — companion paper info now lives in the sidebar's footer area
     instead of as a strip above the map. The body itself doesn't scroll
     on this page; the sidebar inside the map keeps its own internal scroll. */
  body:has(.firefuels-frame) { overflow: hidden; }
  .firefuels-frame { position: relative; height: calc(100vh - 56px); }
  .firefuels-frame > * { width: 100%; height: 100%; }
</style>
