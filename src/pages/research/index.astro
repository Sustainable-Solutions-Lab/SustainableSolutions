---
import BaseLayout from '../../layouts/BaseLayout.astro';
import publications from '../../data/publications.json';
import type { Publication } from '../../lib/types';
import { SYSTEMS, systemMatches } from '../../lib/systems';

// Per-system paper count to show on each card (prefix-matched, so
// energy:electricity etc. roll up under the parent system).
const pubs = publications as Publication[];
const cards = SYSTEMS.map((s) => ({
  ...s,
  count: pubs.filter((p) => systemMatches(p.system, s.slug)).length,
}));
---

<BaseLayout title="Research" showCoordReadout={true}>
  <section class="container-content pt-8 pb-6">
    <p class="eyebrow mb-4">RESEARCH</p>
    <h1>What we study</h1>
    <p class="lede max-w-prose mt-4">
      The lab studies the unavoidable environmental tradeoffs of energy, food,
      and material security — and the most viable paths to a sustainable future.
      Our work spans six interconnected systems.
    </p>
  </section>

  <section class="container-content pb-24">
    <ul class="grid md:grid-cols-2 gap-px bg-rule border border-rule list-none p-0 m-0">
      {cards.map((s) => (
        <li class="bg-paper m-0 p-0">
          <a
            href={`/research/${s.slug}`}
            class="flex flex-col h-full p-6 hover:bg-paper-2 transition-colors border-b-0"
          >
            <p class="eyebrow mb-2">SYSTEM</p>
            <h3 class="m-0">{s.title}</h3>
            <p class="text-ink-2 text-sm mt-2 mb-0" style="line-height: 1.5;">
              {s.summary}
            </p>
            <p class="font-mono text-xs text-ink-3 mt-4 mb-0 uppercase tracking-wider">
              {s.count} paper{s.count === 1 ? '' : 's'}
              <span class="dot">·</span>
              <span class="text-ink-2">Read more →</span>
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
