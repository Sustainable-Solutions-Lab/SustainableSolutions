---
// Lab-scope heatmap, reference-style.
//
// Columns = systems       (Energy · Food · Water · Materials · Climate · Health)
// Rows    = response type, two sections separated by a section header:
//             MITIGATION:  General · Trade · Carbon mgmt
//             IMPACTS &
//             ADAPTATION:  General · Air pollution · Heat · Drought · Fire · Flooding
//
// Cell color is mapped from the paper count via the lab's full
// ColorBrewer Spectral palette: low counts at the cool/green end,
// high counts at the warm/red end, no-papers cells stay paper.
// Single global scale (max count anywhere) so absolute density reads
// across the whole figure.
//
// Sub-tag rollup: system=energy:electricity → Energy column, response=
// impacts:drought → Drought row, etc. (prefix match).

import publications from '../data/publications.json';
import type { Publication } from '../lib/types';
import { totalCitations as pubTotalCitations, recentCitations as pubRecentCitations } from '../lib/citations';

const SYSTEMS = [
  { key: 'energy',    label: 'Energy'    },
  { key: 'food',      label: 'Food'      },
  { key: 'water',     label: 'Water'     },
  { key: 'materials', label: 'Materials' },
  { key: 'climate',   label: 'Climate'   },
  { key: 'health',    label: 'Health'    },
] as const;

const MIT_ROWS = [
  { key: 'general',           label: 'General',     match: 'mitigation' },
  { key: 'trade',             label: 'Trade',       match: 'mitigation:trade' },
  { key: 'carbon-management', label: 'Carbon mgmt', match: 'mitigation:carbon-management' },
] as const;

const IMP_ROWS = [
  { key: 'general',       label: 'General',       match: 'impacts' },
  { key: 'air-pollution', label: 'Air pollution', match: 'impacts:air-pollution' },
  { key: 'heat',          label: 'Heat',          match: 'impacts:heat' },
  { key: 'drought',       label: 'Drought',       match: 'impacts:drought' },
  { key: 'fire',          label: 'Fire',          match: 'impacts:fire' },
  { key: 'flooding',      label: 'Flooding',      match: 'impacts:flooding' },
] as const;

const pubs = publications as Publication[];

function axisMatches(values: string[], target: string): boolean {
  for (const v of values) {
    if (v === target) return true;
    if (v.startsWith(target + ':')) return true;
  }
  return false;
}

const RECENT_YEARS = 3;
const currentYear = new Date().getFullYear();
const recentCutoff = currentYear - RECENT_YEARS + 1;

// Key on row.match (which is unique) rather than row.key — MIT and IMP
// both have a "general" sub-row, and keying on row.key collided so the
// IMP general count silently overwrote the MIT general count.
const cellPapers: Record<string, number> = {};
const cellCitations: Record<string, number> = {};
const cellRecentCites: Record<string, number> = {};
const cellRecentPapers: Record<string, number> = {};

for (const sys of SYSTEMS) {
  for (const row of [...MIT_ROWS, ...IMP_ROWS]) {
    let papers = 0, citations = 0, recCites = 0, recPapers = 0;
    for (const p of pubs) {
      const s = (p.system ?? []) as string[];
      const r = (p.response ?? []) as string[];
      if (axisMatches(s, sys.key) && axisMatches(r, row.match)) {
        papers++;
        citations += pubTotalCitations(p);
        recCites += pubRecentCitations(p, RECENT_YEARS);
        if (typeof p.year === 'number' && p.year >= recentCutoff) recPapers++;
      }
    }
    const k = `${sys.key}|${row.match}`;
    cellPapers[k] = papers;
    cellCitations[k] = citations;
    cellRecentCites[k] = recCites;
    cellRecentPapers[k] = recPapers;
  }
}

// Rank-percentile color: the data is heavy-tailed at every metric, so
// value scales pile cells into one half of the palette. Sorting non-zero
// values per metric and mapping by rank gives even spread blue→wine
// regardless of distribution skew. Computed per metric so each mode has
// its own ramp anchored to that metric's own min/max/distribution.
function sortedNonZero(map: Record<string, number>): number[] {
  return Object.values(map).filter((n) => n > 0).sort((a, b) => a - b);
}
const rankLists = {
  papers:           sortedNonZero(cellPapers),
  citations:        sortedNonZero(cellCitations),
  'recent-cites':   sortedNonZero(cellRecentCites),
  'recent-papers':  sortedNonZero(cellRecentPapers),
};

function cellBg(value: number, sorted: number[]): string {
  if (!value) return 'var(--paper-2)';
  const lower = sorted.filter((n) => n < value).length;
  const equal = sorted.filter((n) => n === value).length;
  const denom = Math.max(1, sorted.length - 1);
  const rank = (lower + (equal - 1) / 2) / denom;
  const idx = Math.max(1, Math.min(10, Math.round(10 - rank * 9)));
  return `var(--spectral-${idx})`;
}

// Initial render uses the "papers" metric. JS toggle re-colors and
// re-labels in place using the embedded rank lists + per-cell data attrs.
const labelPapers = (n: number) => `${n} paper${n === 1 ? '' : 's'}`;
---

<figure class="scope-figure">
  <p class="scope-eyebrow">
    <span class="cardinal-dot"></span>FIGURE · LAB SCOPE
  </p>
  <h3 class="scope-headline">Where the lab works</h3>
  <p class="scope-subtitle">
    <em>Publications by system and topic</em>
  </p>

  <div class="scope-modes" role="radiogroup" aria-label="Recolor matrix by metric">
    <span class="modes-label">Color by</span>
    <button class="mode-btn is-active" type="button" data-mode="papers"        aria-pressed="true">Papers</button>
    <button class="mode-btn"           type="button" data-mode="citations"     aria-pressed="false">Citations</button>
    <button class="mode-btn"           type="button" data-mode="recent-cites"  aria-pressed="false">Recent cites</button>
    <button class="mode-btn"           type="button" data-mode="recent-papers" aria-pressed="false">Recent papers</button>
  </div>

  <div
    class="scope-grid"
    data-rank-lists={JSON.stringify(rankLists)}
    data-recent-years={RECENT_YEARS}
  >
    {/* Header row: empty section col + empty row-label col + 6 system labels. */}
    <div></div>
    <div></div>
    {SYSTEMS.map((s) => (
      <div class="col-label">{s.label}</div>
    ))}

    {/*
      Section labels rotated 90° as a left spine instead of horizontal banners,
      so every data row sits on the same vertical rhythm. The label spans the
      height of its rows via grid-row: span N.
    */}
    <div class="section-label section-mit" style={`grid-row: span ${MIT_ROWS.length};`}>
      <span class="section-label-text">Mitigation</span>
    </div>

    {MIT_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const k = `${s.key}|${row.match}`;
          const cellLabel = `${s.label} × Mitigation: ${row.label}`;
          const papers = cellPapers[k] ?? 0;
          return (
            <a
              class="cell"
              href={`/publications?system=${encodeURIComponent(s.key)}&response=${encodeURIComponent(row.match)}`}
              style={`background-color: ${cellBg(papers, rankLists.papers)};`}
              data-papers={papers}
              data-citations={cellCitations[k] ?? 0}
              data-recent-cites={cellRecentCites[k] ?? 0}
              data-recent-papers={cellRecentPapers[k] ?? 0}
              data-label={cellLabel}
              title={`${cellLabel} · ${labelPapers(papers)}`}
              aria-label={`${cellLabel} — ${labelPapers(papers)}`}
            ></a>
          );
        })}
      </>
    ))}

    <div class="section-label section-imp" style={`grid-row: span ${IMP_ROWS.length};`}>
      <span class="section-label-text">Impacts &amp;<br />adaptation</span>
    </div>

    {IMP_ROWS.map((row) => (
      <>
        <div class="row-label">{row.label}</div>
        {SYSTEMS.map((s) => {
          const k = `${s.key}|${row.match}`;
          const cellLabel = `${s.label} × Impacts: ${row.label}`;
          const papers = cellPapers[k] ?? 0;
          return (
            <a
              class="cell"
              href={`/publications?system=${encodeURIComponent(s.key)}&response=${encodeURIComponent(row.match)}`}
              style={`background-color: ${cellBg(papers, rankLists.papers)};`}
              data-papers={papers}
              data-citations={cellCitations[k] ?? 0}
              data-recent-cites={cellRecentCites[k] ?? 0}
              data-recent-papers={cellRecentPapers[k] ?? 0}
              data-label={cellLabel}
              title={`${cellLabel} · ${labelPapers(papers)}`}
              aria-label={`${cellLabel} — ${labelPapers(papers)}`}
            ></a>
          );
        })}
      </>
    ))}

    {/* Colorbar lives inside the grid so it spans the system-cell
        columns only, not the spine + row-label gutter to its left. */}
    <div class="scope-colorbar">
      <span class="colorbar-end">Few</span>
      <div class="colorbar-gradient" aria-hidden="true"></div>
      <span class="colorbar-end colorbar-end-high">Many</span>
    </div>
  </div>
</figure>

<style>
  .scope-figure {
    margin: 0;
    width: 100%;
  }
  .scope-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cardinal);
    margin: 0 0 6px;
  }
  .scope-headline {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .scope-subtitle {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 10px;
  }

  /* Mode-toggle row: monospace eyebrow buttons for switching the metric
     used to color cells. Active button gets ink color + cardinal underline. */
  .scope-modes {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px 6px;
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .modes-label {
    color: var(--ink-3);
    margin-right: 2px;
  }
  .mode-btn {
    background: transparent;
    border: 0;
    color: var(--ink-3);
    cursor: pointer;
    padding: 2px 4px;
    font: inherit;
    text-transform: inherit;
    letter-spacing: inherit;
    border-bottom: 1px solid transparent;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .mode-btn:hover { color: var(--ink-2); }
  .mode-btn.is-active {
    color: var(--ink);
    font-weight: 700;
    border-bottom-color: var(--cardinal);
  }

  .scope-grid {
    display: grid;
    grid-template-columns:
      40px                                /* spine: rotated section label + colored rule */
      minmax(80px, max-content)           /* row labels */
      repeat(6, minmax(46px, 1fr));       /* system cells */
    gap: 3px;
    align-items: stretch;
  }

  /* Column headers (sans-serif title case, no wrap, more reading-friendly
     than uppercase mono at this size). */
  .col-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-align: center;
    color: var(--ink-2);
    padding: 0 0 4px;
    white-space: nowrap;
    align-self: end;
  }

  /* Spine column: container is NOT rotated, so the colored rule (::before)
     can sit on its visual right edge with predictable insets. The rotated
     text lives in a child .section-label-text whose inset reserves space
     for the rule, preventing the text from overlapping it. */
  .section-label {
    grid-column: 1;
    position: relative;
  }
  .section-label::before {
    content: '';
    position: absolute;
    top: 8px;
    bottom: 8px;
    right: 4px;
    width: 2px;
    background: currentColor;
  }
  .section-label-text {
    position: absolute;
    inset: 0 14px 0 0;                   /* leave the right edge clear for the rule */
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    line-height: 1.2;
    text-align: center;
  }
  .section-mit { color: var(--spectral-10); }
  .section-imp { color: var(--spectral-2); }

  .row-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-2);
    text-align: right;
    padding-right: 8px;
    align-self: center;
    white-space: nowrap;
  }

  .cell {
    background: var(--paper-2);
    border-radius: 3px;
    height: 22px;
    border-bottom: 0;
    transition: outline 0.12s ease, transform 0.12s ease, background-color 0.2s ease;
    cursor: pointer;
  }
  .cell:hover {
    outline: 1.5px solid var(--ink);
    outline-offset: -1px;
  }

  .scope-colorbar {
    grid-column: 3 / -1;                  /* under the cells, not under labels */
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
  }
  .colorbar-end {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    flex: none;
  }
  .colorbar-gradient {
    flex: 1;
    height: 8px;
    border-radius: 4px;
    background: linear-gradient(
      to right,
      var(--spectral-10) 0%,
      var(--spectral-9) 14%,
      var(--spectral-8) 28%,
      var(--spectral-7) 42%,
      var(--spectral-5) 56%,
      var(--spectral-4) 70%,
      var(--spectral-3) 84%,
      var(--spectral-2) 92%,
      var(--spectral-1) 100%
    );
  }
</style>

<script is:inline>
  // Mode toggle for the scope matrix: recolor cells in place using the
  // metric the user picked. Rank-percentile scaling matches the build-time
  // logic so colors stay aligned with the colorbar regardless of metric.
  (function () {
    const grid = document.querySelector('.scope-grid');
    if (!grid) return;
    const ranks = JSON.parse(grid.dataset.rankLists || '{}');
    const recentYears = parseInt(grid.dataset.recentYears || '3', 10);
    const cells = grid.querySelectorAll('.cell');
    const buttons = document.querySelectorAll('.mode-btn');

    function cellBg(value, sortedList) {
      if (!value || !sortedList || !sortedList.length) return 'var(--paper-2)';
      let lower = 0, equal = 0;
      for (const n of sortedList) {
        if (n < value) lower++;
        else if (n === value) equal++;
      }
      const denom = Math.max(1, sortedList.length - 1);
      const rank = (lower + (equal - 1) / 2) / denom;
      const idx = Math.max(1, Math.min(10, Math.round(10 - rank * 9)));
      return 'var(--spectral-' + idx + ')';
    }

    // Map data-mode → camelCase dataset key (recent-cites → recentCites).
    function dskey(mode) {
      return mode.replace(/-([a-z])/g, function (_, c) { return c.toUpperCase(); });
    }

    const fmt = {
      'papers':         function (n) { return n + ' paper' + (n === 1 ? '' : 's'); },
      'citations':      function (n) { return Number(n).toLocaleString() + ' citation' + (n === 1 ? '' : 's'); },
      'recent-cites':   function (n) { return Number(n).toLocaleString() + ' recent citation' + (n === 1 ? '' : 's') + ' (' + recentYears + 'yr)'; },
      'recent-papers':  function (n) { return n + ' recent paper' + (n === 1 ? '' : 's') + ' (' + recentYears + 'yr)'; },
    };

    function applyMode(mode) {
      const sortedList = ranks[mode];
      if (!sortedList) return;
      const key = dskey(mode);
      const format = fmt[mode];
      cells.forEach(function (cell) {
        const v = parseFloat(cell.dataset[key] || '0') || 0;
        cell.style.backgroundColor = cellBg(v, sortedList);
        const label = cell.dataset.label || '';
        cell.setAttribute('aria-label', label + ' — ' + format(v));
        cell.setAttribute('title', label + ' · ' + format(v));
      });
      buttons.forEach(function (b) {
        const active = b.dataset.mode === mode;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    buttons.forEach(function (b) {
      b.addEventListener('click', function () { applyMode(b.dataset.mode); });
    });
  })();
</script>
