---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import publications from '../data/publications.json';
import people from '../data/people.json';
import type { Publication, Person } from '../lib/types';
import { splitAndLinkAuthors } from '../lib/author-links';
import { ROLE_COLORS } from '../lib/roles';

const all = (publications as Publication[])
  .slice()
  .sort((a, b) => b.year - a.year || (b.month ?? 0) - (a.month ?? 0));

const years = [...new Set(all.map((p) => p.year))].sort((a, b) => b - a);
const themes = [...new Set(all.flatMap((p) => p.themes ?? []))].sort();

// Lab-author filter options: any lab member detected in at least one
// publication's authors string. Auto-derived from author-name matching so
// the Sheet's lab_authors column is no longer required to populate this.
const peopleArr = people as Person[];
const detectedSlugs = new Set<string>();
for (const pub of all) {
  for (const seg of splitAndLinkAuthors(pub.authors ?? '', peopleArr)) {
    if (seg.slug) detectedSlugs.add(seg.slug);
  }
}
const labAuthorOptions = peopleArr
  .filter((p) => detectedSlugs.has(p.slug))
  .sort((a, b) => a.name.localeCompare(b.name));

const total = all.length;
---

<BaseLayout title="Publications">
  <section class="container-content pt-16 pb-8">
    <p class="eyebrow mb-4">PUBLICATIONS</p>
    <h1>Peer-reviewed work</h1>
    <p class="lede max-w-prose mt-4">
      Reverse chronological. Filter by theme, year, or featured status; search
      across titles, authors, and journals.
    </p>
    <p class="font-mono text-xs uppercase tracking-wider mt-3 m-0 text-ink-3">
      Lab authors:
      <span style={`color: ${ROLE_COLORS.student}; font-weight: 600;`}>Student</span>
      <span class="dot">·</span>
      <span style={`color: ${ROLE_COLORS.postdoc}; font-weight: 600;`}>Postdoc</span>
      <span class="dot">·</span>
      <span style={`color: ${ROLE_COLORS.staff}; font-weight: 600;`}>Staff</span>
    </p>
  </section>

  <section class="container-content pb-24">
    <div
      class="flex flex-wrap items-center gap-4 py-4 mb-2 border-y border-rule bg-paper sticky z-20"
      style="top: 56px;"
      role="search"
    >
      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Search</span>
        <input
          id="pub-search"
          type="search"
          placeholder="Title, author, journal…"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm); min-width: 16ch;"
        />
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Year</span>
        <select
          id="pub-year"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All</option>
          {years.map((y) => <option value={y}>{y}</option>)}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Theme</span>
        <select
          id="pub-theme"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="">All</option>
          {themes.map((t) => <option value={t}>{t}</option>)}
        </select>
      </label>

      {labAuthorOptions.length > 0 && (
        <label class="flex items-center gap-2 text-sm">
          <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Author</span>
          <select
            id="pub-author"
            class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
            style="border-radius: var(--radius-sm);"
          >
            <option value="">All</option>
            {labAuthorOptions.map((p) => <option value={p.slug}>{p.name}</option>)}
          </select>
        </label>
      )}

      <label class="flex items-center gap-2 text-sm">
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Sort</span>
        <select
          id="pub-sort"
          class="bg-paper-2 border border-rule px-2 py-1 text-sm font-sans focus:outline-none focus:border-ink"
          style="border-radius: var(--radius-sm);"
        >
          <option value="date">Most recent</option>
          <option value="total-citations">Total citations</option>
          <option value="citations-per-year">Citations / year</option>
          <option value="recent-citations">Recent citations (3 yr)</option>
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <input id="pub-featured" type="checkbox" class="accent-cardinal" />
        <span class="font-mono text-xs uppercase tracking-wider text-ink-3">Featured only</span>
      </label>

      <span id="pub-count" class="ml-auto font-mono text-xs text-ink-3">
        {total} of {total}
      </span>
    </div>

    <ul id="pub-list" class="list-none p-0 m-0">
      {all.map((pub) => <PublicationItem pub={pub} />)}
    </ul>

    <p id="pub-empty" hidden class="py-12 text-center text-ink-3 text-sm">
      No publications match the current filters.
    </p>
  </section>
</BaseLayout>

{/* Altmetric + Dimensions badge embeds — read data-doi attributes
    rendered into featured publication cards. Loaded only on this page. */}
<script async src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"></script>
<script async src="https://badge.dimensions.ai/badge.js" charset="utf-8"></script>

<script is:inline>
  (function () {
    const search = document.getElementById('pub-search');
    const yearSel = document.getElementById('pub-year');
    const themeSel = document.getElementById('pub-theme');
    const authorSel = document.getElementById('pub-author');
    const sortSel = document.getElementById('pub-sort');
    const feat = document.getElementById('pub-featured');
    const list = document.getElementById('pub-list');
    const empty = document.getElementById('pub-empty');
    const count = document.getElementById('pub-count');
    if (!list || !count) return;

    const items = Array.from(list.querySelectorAll('[data-pub]'));
    const total = items.length;

    const sortKey = (li) => {
      const k = sortSel?.value ?? 'date';
      if (k === 'date') {
        return -(parseInt(li.dataset.year || '0', 10) * 100 + parseInt(li.dataset.month || '0', 10));
      }
      if (k === 'total-citations')      return -parseFloat(li.dataset.totalCitations || '0');
      if (k === 'citations-per-year')   return -parseFloat(li.dataset.citationsPerYear || '0');
      if (k === 'recent-citations')     return -parseFloat(li.dataset.recentCitations || '0');
      return 0;
    };

    const applySort = () => {
      const sorted = [...items].sort((a, b) => sortKey(a) - sortKey(b));
      for (const li of sorted) list.appendChild(li);
    };

    const apply = () => {
      const q = (search?.value ?? '').trim().toLowerCase();
      const y = yearSel?.value ?? '';
      const t = themeSel?.value ?? '';
      const a = authorSel?.value ?? '';
      const f = feat?.checked ?? false;

      let visible = 0;
      for (const li of items) {
        const themes = (li.dataset.themes ?? '').split(',').filter(Boolean);
        const labAuthors = (li.dataset.labAuthors ?? '').split(',').filter(Boolean);
        const ok =
          (!q || (li.dataset.search ?? '').includes(q)) &&
          (!y || li.dataset.year === y) &&
          (!t || themes.includes(t)) &&
          (!a || labAuthors.includes(a)) &&
          (!f || li.dataset.featured === 'true');
        li.hidden = !ok;
        if (ok) visible++;
      }

      count.textContent = `${visible} of ${total}`;
      if (empty) empty.hidden = visible !== 0;
    };

    // Pre-fill the Author select from `?author=<slug>` so /publications?author=X
    // arrives pre-filtered (used by the "see all" link on people detail pages).
    const params = new URLSearchParams(window.location.search);
    const authorParam = params.get('author');
    if (authorParam && authorSel) {
      const opt = Array.from(authorSel.options).find((o) => o.value === authorParam);
      if (opt) authorSel.value = authorParam;
    }
    const sortParam = params.get('sort');
    if (sortParam && sortSel) sortSel.value = sortParam;

    [search, yearSel, themeSel, authorSel, feat].forEach((el) => {
      el?.addEventListener('input', apply);
      el?.addEventListener('change', apply);
    });
    sortSel?.addEventListener('change', applySort);

    applySort();
    apply();
  })();
</script>
